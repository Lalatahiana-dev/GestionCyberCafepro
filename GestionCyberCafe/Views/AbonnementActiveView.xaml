<UserControl x:Class="Gestion_CyberCafe.Views.Abonnement.Pages.AbonnementActiveView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F3F4F6">

    <Grid Margin="15">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ================= HEADER ================= -->

        <Border Grid.Row="0"
                Background="White"
                CornerRadius="10"
                Padding="15"
                Margin="0,0,0,10"
                BorderBrush="#E5E7EB"
                BorderThickness="1">

            <StackPanel>

                <TextBlock Text="📶 ABONNEMENTS ACTIFS"
                           FontSize="22"
                           FontWeight="Bold"
                           Margin="0,0,0,15"/>

                <Grid>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="3*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Recherche -->

                    <TextBox x:Name="txtRecherche"
                             Grid.Column="0"
                             Height="35"
                             Margin="0,0,10,0"
                             TextChanged="TxtRecherche_TextChanged"/>

                    <!-- Refresh -->

                    <Button Grid.Column="1"
                            Content="🔄 Actualiser"
                            Width="120"
                            Height="35"
                            Margin="0,0,10,0"
                            Click="BtnRefresh_Click"/>

                    <!-- Total -->

                    <TextBlock x:Name="txtTotal"
                               Grid.Column="2"
                               VerticalAlignment="Center"
                               FontWeight="Bold"
                               FontSize="14"
                               Text="0 abonnement"/>

                </Grid>

            </StackPanel>

        </Border>

        <!-- ================= LISTE ================= -->

        <Border Grid.Row="1"
                Background="White"
                CornerRadius="10"
                Padding="10"
                BorderBrush="#E5E7EB"
                BorderThickness="1">

            <DataGrid x:Name="dgAbonnements"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      CanUserAddRows="False" SelectionChanged="dgAbonnements_SelectionChanged">

                <DataGrid.Columns>

                    <DataGridTextColumn Header="Nom"
                        Binding="{Binding Client.Nom}"
                        Width="120"/>

                    <DataGridTextColumn Header="Prénom"
                        Binding="{Binding Client.Prenom}"
                        Width="120"/>

                    <DataGridTextColumn Header="Téléphone"
                        Binding="{Binding Client.Telephone}"
                        Width="120"/>

                    <DataGridTextColumn Header="Accès"
                        Binding="{Binding TypeAcces}"
                        Width="100"/>

                    <DataGridTextColumn Header="Forfait"
                        Binding="{Binding TypeForfait}"
                        Width="100"/>

                    <DataGridTextColumn Header="Appareils"
                        Binding="{Binding NombreAppareils}"
                        Width="90"/>

                    <DataGridTextColumn Header="Début"
                        Binding="{Binding DateDebut}"
                        Width="140"/>

                    <DataGridTextColumn Header="Expiration"
                        Binding="{Binding DateExpiration}"
                        Width="140"/>

                    <DataGridTextColumn Header="Montant"
                        Binding="{Binding Montant}"
                        Width="100"/>

                    <DataGridTextColumn Header="Statut"
                        Binding="{Binding Statut}"
                        Width="80"/>
                    
                    <DataGridTemplateColumn Header="Actions" Width="180">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>

                                <StackPanel Orientation="Horizontal">

                                    <!-- Voir -->
                                    <Button Content="👁"
                        Width="30"
                        Margin="2"
                        Click="BtnVoir_Click"/>

                                    <!-- Modifier -->
                                    <Button Content="✏"
                        Width="30"
                        Margin="2"
                        Click="BtnModifier_Click"/>
                                    <Button Content="🔄"
                     Width="80"
                     Margin="2"
                    Background="#2563EB"
                    Foreground="White"
                    Click="BtnRenouveler_Click"/>

                                    <!-- Suspendre -->
                                    <Button Content="⛔"
                        Width="30"
                        Margin="2"
                        Background="Orange"
                        Click="BtnSuspendre_Click"/>

                                    <!-- Delete -->
                                    <Button Content="❌"
                        Width="30"
                        Margin="2"
                        Background="Red"
                        Foreground="White"
                        Click="BtnDelete_Click"/>

                                </StackPanel>

                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>

        </Border>

    </Grid>

</UserControl>