<UserControl x:Class="Gestion_CyberCafe.Views.Abonnement.Pages.AbonnementActiveView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:fa="http://schemas.fontawesome.io/icons/"
             Background="#F3F4F6">

    <Grid Margin="15">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ================= HEADER ================= -->
        <Border Grid.Row="0"
                Background="White"
                CornerRadius="12"
                Padding="15"
                Margin="0,0,0,12"
                BorderBrush="#E5E7EB"
                BorderThickness="1">

            <StackPanel>

                <!-- TITLE -->
                <StackPanel Orientation="Horizontal"
                            Margin="0,0,0,15">

                    <fa:ImageAwesome Icon="Wifi"
                                     Width="18"
                                     Foreground="#2563EB"
                                     Margin="0,0,8,0"/>

                    <TextBlock Text="ABONNEMENTS ACTIFS"
                               FontSize="22"
                               FontWeight="SemiBold"
                               Foreground="#111827"/>
                </StackPanel>

                <!-- SEARCH + ACTIONS -->
                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center">

                    <!-- SEARCH BLOCK -->
                    <StackPanel Width="360">

                        <TextBlock Text="Recherche (nom, téléphone, forfait...)"
                                   Foreground="#6B7280"
                                   Margin="0,0,0,5"/>

                        <Border Background="#F9FAFB"
                                BorderBrush="#E5E7EB"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="6">

                            <Grid Height="36">

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="35"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <fa:ImageAwesome Icon="Search"
                                                 Width="14"
                                                 Foreground="#6B7280"
                                                 HorizontalAlignment="Center"
                                                 VerticalAlignment="Center"/>

                                <TextBox x:Name="txtRecherche"
                                         Grid.Column="1"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         VerticalContentAlignment="Center"/>

                            </Grid>

                        </Border>
                    </StackPanel>

                    <!-- BOUTON RECHERCHER -->
                    <Button Margin="10,20,5,0"
                            Height="36"
                            Width="120"
                            Background="#10B981"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="BtnRechercher_Click">

                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center">

                            <fa:ImageAwesome Icon="Search"
                                             Width="14"
                                             Margin="0,0,6,0"/>

                            <TextBlock Text="Rechercher"/>
                        </StackPanel>

                    </Button>

                    <!-- ACTUALISER -->
                    <Button Margin="5,20,10,0"
                            Height="36"
                            Width="120"
                            Background="#2563EB"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="BtnRefresh_Click">

                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center">

                            <fa:ImageAwesome Icon="RotateRight"
                                             Width="14"
                                             Margin="0,0,6,0"/>

                            <TextBlock Text="Actualiser"/>
                        </StackPanel>

                    </Button>

                    <!-- TOTAL -->
                    <Border Background="#F3F4F6"
                            CornerRadius="8"
                            Padding="10"
                            Margin="10,20,0,0">

                        <TextBlock x:Name="txtTotal"
                                   FontWeight="SemiBold"
                                   Foreground="#111827"
                                   Text="0 abonnement"/>
                    </Border>

                </StackPanel>

            </StackPanel>

        </Border>

        <!-- ================= TABLE ================= -->
        <Border Grid.Row="1"
                Background="White"
                CornerRadius="12"
                Padding="10"
                BorderBrush="#E5E7EB"
                BorderThickness="1">

            <DataGrid x:Name="dgAbonnements"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      GridLinesVisibility="None"
                      RowHeight="40"
                      HeadersVisibility="Column">

                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#F3F4F6"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="Height" Value="42"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>

                <DataGrid.Columns>

                    <DataGridTextColumn Header="Nom" Binding="{Binding Client.Nom}" Width="120"/>
                    <DataGridTextColumn Header="Prénom" Binding="{Binding Client.Prenom}" Width="120"/>
                    <DataGridTextColumn Header="Téléphone" Binding="{Binding Client.Telephone}" Width="120"/>
                    <DataGridTextColumn Header="Accès" Binding="{Binding TypeAcces}" Width="100"/>
                    <DataGridTextColumn Header="Forfait" Binding="{Binding TypeForfait}" Width="100"/>
                    <DataGridTextColumn Header="Appareils" Binding="{Binding NombreAppareils}" Width="90"/>
                    <DataGridTextColumn Header="Début" Binding="{Binding DateDebut}" Width="140"/>
                    <DataGridTextColumn Header="Expiration" Binding="{Binding DateExpiration}" Width="140"/>
                    <DataGridTextColumn Header="Montant" Binding="{Binding Montant}" Width="100"/>
                    <DataGridTextColumn Header="Statut" Binding="{Binding Statut}" Width="80"/>

                    <!-- ACTIONS -->
                    <DataGridTemplateColumn Header="Actions" Width="200">

                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>

                                <StackPanel Orientation="Horizontal">

                                    <Button Background="#6B7280"
                                            Foreground="White"
                                            Margin="2"
                                            Width="32"
                                            Height="32"
                                            Click="BtnVoir_Click">
                                        <fa:ImageAwesome Icon="Eye" Width="12"/>
                                    </Button>

                                    <Button Background="#2563EB"
                                            Foreground="White"
                                            Margin="2"
                                            Width="32"
                                            Height="32"
                                            Click="BtnModifier_Click">
                                        <fa:ImageAwesome Icon="Edit" Width="12"/>
                                    </Button>

                                    <Button Background="#F59E0B"
                                            Foreground="White"
                                            Margin="2"
                                            Width="32"
                                            Height="32"
                                            Click="BtnRenouveler_Click">
                                        <fa:ImageAwesome Icon="RotateRight" Width="12"/>
                                    </Button>

                                    <Button Background="#DC2626"
                                            Foreground="White"
                                            Margin="2"
                                            Width="32"
                                            Height="32"
                                            Click="BtnSuspendre_Click">
                                        <fa:ImageAwesome Icon="Ban" Width="12"/>
                                    </Button>

                                    <Button Background="#111827"
                                            Foreground="White"
                                            Margin="2"
                                            Width="32"
                                            Height="32"
                                            Click="BtnDelete_Click">
                                        <fa:ImageAwesome Icon="Trash" Width="12"/>
                                    </Button>

                                </StackPanel>

                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>

                    </DataGridTemplateColumn>

                </DataGrid.Columns>

            </DataGrid>

        </Border>

    </Grid>

</UserControl>