<UserControl x:Class="GestionCyberCafe.Views.AbonnementHistoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="700"
             d:DesignWidth="1200"
             Background="#F3F4F6">

    <Grid Margin="15">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ================= HEADER ================= -->

        <Border Grid.Row="0"
                Background="White"
                CornerRadius="10"
                Padding="15"
                Margin="0,0,0,10"
                BorderBrush="#E5E7EB"
                BorderThickness="1">

            <StackPanel>

                <TextBlock Text="📜 HISTORIQUE DES ABONNEMENTS"
                           FontSize="24"
                           FontWeight="Bold"
                           Margin="0,0,0,15"/>

                <Grid>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="3*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Recherche -->

                    <TextBox x:Name="txtRecherche"
                             Grid.Column="0"
                             Height="35"
                             Margin="0,0,10,0"
                             VerticalContentAlignment="Center"/>

                    <!-- Actualiser -->

                    <Button x:Name="btnRefresh"
                            Grid.Column="1"
                            Content="🔄 Actualiser"
                            Width="120"
                            Height="35"
                            Margin="0,0,10,0"/>

                    <!-- Total -->

                    <TextBlock x:Name="txtTotal"
                               Grid.Column="2"
                               VerticalAlignment="Center"
                               FontWeight="Bold"
                               FontSize="14"
                               Text="0 abonnement(s)"/>

                </Grid>

            </StackPanel>

        </Border>

        <!-- ================= LISTE ================= -->

        <Border Grid.Row="1"
                Background="White"
                CornerRadius="10"
                Padding="10"
                BorderBrush="#E5E7EB"
                BorderThickness="1">

            <DataGrid x:Name="dgHistorique"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserAddRows="False"
                      SelectionMode="Single"
                      HeadersVisibility="Column">

                <DataGrid.Columns>

                    <!-- Client -->

                    <DataGridTextColumn Header="Nom"
                                        Binding="{Binding Client.Nom}"
                                        Width="120"/>

                    <DataGridTextColumn Header="Prénom"
                                        Binding="{Binding Client.Prenom}"
                                        Width="120"/>

                    <DataGridTextColumn Header="Téléphone"
                                        Binding="{Binding Client.Telephone}"
                                        Width="130"/>

                    <!-- Abonnement -->

                    <DataGridTextColumn Header="Accès"
                                        Binding="{Binding TypeAcces}"
                                        Width="120"/>

                    <DataGridTextColumn Header="Forfait"
                                        Binding="{Binding TypeForfait}"
                                        Width="120"/>

                    <DataGridTextColumn Header="Appareils"
                                        Binding="{Binding NombreAppareils}"
                                        Width="90"/>

                    <!-- Dates -->

                    <DataGridTextColumn Header="Date Début"
                                        Binding="{Binding DateDebut}"
                                        Width="150"/>

                    <DataGridTextColumn Header="Expiration"
                                        Binding="{Binding DateExpiration}"
                                        Width="150"/>

                    <!-- Finances -->

                    <DataGridTextColumn Header="Montant"
                                        Binding="{Binding Montant}"
                                        Width="120"/>

                    <!-- Statut -->

                    <DataGridTextColumn Header="Statut"
                                        Binding="{Binding Statut}"
                                        Width="100"/>

                    <!-- Supprimé -->

                    <DataGridCheckBoxColumn Header="Supprimé"
                                            Binding="{Binding IsDeleted}"
                                            Width="90"/>

                    <!-- Action -->

                    <DataGridTemplateColumn Header="Action" Width="180">

                        <DataGridTemplateColumn.CellTemplate>

                            <DataTemplate>

                                <StackPanel Orientation="Horizontal">

                                    <Button Content="👁"
                        Width="35"
                        Margin="2"
                        Click="BtnVoir_Click"/>

                                    <Button Content="▶"
                        Width="35"
                        Margin="2"
                        Background="#16A34A"
                        Foreground="White"
                        Click="BtnReactiver_Click"/>
                                    <Button Content="❌"
        Width="35"
        Margin="2"
        Background="Red"
        Foreground="White"
        Click="BtnDelete_Click"/>

                                </StackPanel>

                            </DataTemplate>

                        </DataGridTemplateColumn.CellTemplate>

                    </DataGridTemplateColumn>

                </DataGrid.Columns>

            </DataGrid>

        </Border>

    </Grid>

</UserControl>