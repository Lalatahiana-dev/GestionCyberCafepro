<UserControl x:Class="GestionCyberCafe.Views.AbonnementHistoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:fa="http://schemas.fontawesome.io/icons/"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="700"
             d:DesignWidth="1200"
             Background="#F3F4F6">

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ================= HEADER ================= -->

        <Border Grid.Row="0"
                Background="White"
                CornerRadius="14"
                Padding="18"
                Margin="0,0,0,15"
                BorderBrush="#E5E7EB"
                BorderThickness="1">

            <StackPanel>

                <!-- TITLE -->
                <StackPanel Orientation="Horizontal"
                            Margin="0,0,0,20">

                    <fa:ImageAwesome Icon="History"
                                     Width="14"
                                     Height="14"
                                     Foreground="#2563EB"
                                     Margin="0,0,10,0"/>

                    <TextBlock Text="Historique des Abonnements"
                               FontSize="22"
                               FontWeight="SemiBold"
                               Foreground="#111827"/>

                </StackPanel>

                <!-- FILTERS -->
                <Grid>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="320"/>
                        <ColumnDefinition Width="170"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- RECHERCHE -->
                    <StackPanel Grid.Column="0">

                        <TextBlock Text="Recherche"
                                   Margin="0,0,0,5"
                                   FontWeight="SemiBold"
                                   Foreground="#374151"/>

                        <Border Background="#F9FAFB"
                                BorderBrush="#E5E7EB"
                                BorderThickness="1"
                                CornerRadius="8">

                            <Grid Height="38">

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="40"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <fa:ImageAwesome Icon="Search"
                                                 Width="13"
                                                 Height="13"
                                                 Foreground="#6B7280"
                                                 HorizontalAlignment="Center"
                                                 VerticalAlignment="Center"/>

                                <TextBox x:Name="txtRecherche"
                                         Grid.Column="1"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         VerticalContentAlignment="Center"
                                         TextChanged="txtRecherche_TextChanged"/>

                            </Grid>

                        </Border>

                    </StackPanel>

                    <!-- DATE -->
                    <StackPanel Grid.Column="1"
                                Margin="10,0,0,0">

                        <TextBlock Text="Date"
                                   Margin="0,0,0,5"
                                   FontWeight="SemiBold"
                                   Foreground="#374151"/>

                        <DatePicker x:Name="dpDate"
                                    Height="38"
                                    SelectedDateChanged="dpDate_SelectedDateChanged"/>

                    </StackPanel>

                    <!-- ACTUALISER -->
                    <Button Grid.Column="2"
                            Margin="15,24,10,0"
                            Height="30"
                            Background="#2563EB"
                            
                            Foreground="White"
                            BorderThickness="0"
                            
                            Click="btnRefresh_Click">

                        <StackPanel Orientation="Horizontal">

                            <fa:ImageAwesome Icon="Refresh"
                                             Width="60"
                                             Height="12"
                                             Margin="0,0,6,0"/>

                            
                        </StackPanel>

                    </Button>

                    <!-- TOTAL -->
                    <Border Grid.Column="3"
                            HorizontalAlignment="Right"
                            Margin="0,24,0,0"
                            Background="#EFF6FF"
                            CornerRadius="8"
                            Padding="12,6">

                        <StackPanel Orientation="Horizontal">

                            <fa:ImageAwesome Icon="List"
                                             Width="12"
                                             Height="12"
                                             Foreground="#2563EB"
                                             Margin="0,0,6,0"/>

                            <TextBlock x:Name="txtTotal"
                                       Text="0 abonnement(s)"
                                       FontWeight="SemiBold"
                                       Foreground="#1E40AF"/>

                        </StackPanel>

                    </Border>

                </Grid>

            </StackPanel>

        </Border>

        <!-- ================= TABLE ================= -->

        <Border Grid.Row="1"
                Background="White"
                CornerRadius="14"
                Padding="10"
                BorderBrush="#E5E7EB"
                BorderThickness="1">

            <DataGrid x:Name="dgHistorique"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserAddRows="False"
                      SelectionMode="Single"
                      HeadersVisibility="Column"
                      GridLinesVisibility="None"
                      RowHeight="42"
                      BorderThickness="0"
                      AlternatingRowBackground="#F9FAFB">

                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#F3F4F6"/>
                        <Setter Property="Foreground" Value="#111827"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="Height" Value="42"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>

                <DataGrid.Columns>

                    <DataGridTextColumn Header="Nom" Binding="{Binding Client.Nom}" Width="120"/>
                    <DataGridTextColumn Header="Prénom" Binding="{Binding Client.Prenom}" Width="120"/>
                    <DataGridTextColumn Header="Téléphone" Binding="{Binding Client.Telephone}" Width="130"/>
                    <DataGridTextColumn Header="Accès" Binding="{Binding TypeAcces}" Width="120"/>
                    <DataGridTextColumn Header="Forfait" Binding="{Binding TypeForfait}" Width="120"/>
                    <DataGridTextColumn Header="Appareils" Binding="{Binding NombreAppareils}" Width="90"/>
                    <DataGridTextColumn Header="Début" Binding="{Binding DateDebut}" Width="150"/>
                    <DataGridTextColumn Header="Expiration" Binding="{Binding DateExpiration}" Width="150"/>
                    <DataGridTextColumn Header="Montant" Binding="{Binding Montant}" Width="110"/>
                    <DataGridTextColumn Header="Statut" Binding="{Binding Statut}" Width="100"/>

                    <DataGridCheckBoxColumn Header="Supprimé"
                                            Binding="{Binding IsDeleted}"
                                            Width="90"/>

                    <!-- ACTIONS -->
                    <DataGridTemplateColumn Header="Actions" Width="120">

                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>

                                <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Center">

                                    <Button Width="32"
                                            Height="32"
                                            Margin="2"
                                            Background="#2563EB"
                                            Foreground="White"
                                            Click="BtnVoir_Click">
                                        <fa:ImageAwesome Icon="Eye" Width="12"/>
                                    </Button>

                                    <Button Width="32"
                                            Height="32"
                                            Margin="2"
                                            Background="#16A34A"
                                            Foreground="White"
                                            Click="BtnReactiver_Click">
                                        <fa:ImageAwesome Icon="Play" Width="12"/>
                                    </Button>

                                    <Button Width="32"
                                            Height="32"
                                            Margin="2"
                                            Background="#DC2626"
                                            Foreground="White"
                                            Click="BtnDelete_Click">
                                        <fa:ImageAwesome Icon="Trash" Width="12"/>
                                    </Button>

                                </StackPanel>

                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>

                    </DataGridTemplateColumn>

                </DataGrid.Columns>

            </DataGrid>

        </Border>

    </Grid>

</UserControl>