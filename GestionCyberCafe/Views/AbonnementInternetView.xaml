<UserControl x:Class="Gestion_CyberCafe.Views.Abonnement.Pages.AbonnementInternetView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:fa="http://schemas.fontawesome.io/icons/"
             Background="#F9FAFB">

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ================= HEADER ================= -->

        <Border Grid.Row="0"
                Background="White"
                CornerRadius="14"
                BorderBrush="#E5E7EB"
                BorderThickness="1"
                Padding="15">

            <StackPanel>

                <!-- TITLE -->

                <StackPanel Orientation="Horizontal"
                            Margin="0,0,0,15">

                    <fa:ImageAwesome Icon="Wifi"
                                     Width="18"
                                     Height="18"
                                     Foreground="#2563EB"
                                     Margin="0,0,10,0"/>

                    <TextBlock Text="Gestion des Abonnements Internet"
                               FontSize="22"
                               FontWeight="SemiBold"
                               Foreground="#111827"/>

                </StackPanel>

                <!-- MENU -->

                <Grid>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- FORFAIT -->

                    <Button x:Name="BtnForfait"
                            Grid.Column="0"
                            Height="46"
                            Margin="5"
                            Background="#2563EB"
                            Foreground="White"
                            BorderThickness="0"
                            FontWeight="SemiBold"
                            Cursor="Hand"
                            Click="BtnForfait_Click">

                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center">

                            <fa:ImageAwesome Icon="Archive"
                                             Width="14"
                                             Height="14"
                                             Margin="0,0,8,0"/>

                            <TextBlock Text="FORFAIT"
                                       VerticalAlignment="Center"/>

                        </StackPanel>

                    </Button>

                    <!-- ABONNEMENT LONG -->

                    <Button x:Name="BtnAbonnementLong"
                            Grid.Column="1"
                            Height="46"
                            Margin="5"
                            Background="#F3F4F6"
                            Foreground="#111827"
                            BorderThickness="0"
                            FontWeight="SemiBold"
                            Cursor="Hand"
                            Click="BtnAbonnementLong_Click">

                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center">

                            <fa:ImageAwesome Icon="Calendar"
                                             Width="14"
                                             Height="14"
                                             Foreground="#111827"
                                             Margin="0,0,8,0"/>

                            <TextBlock Text="ABONNEMENT LONG"
                                       VerticalAlignment="Center"/>

                        </StackPanel>

                    </Button>

                </Grid>

            </StackPanel>

        </Border>

        <!-- ================= CONTENT ================= -->

        <Border Grid.Row="1"
                Margin="0,15,0,0"
                Background="White"
                CornerRadius="14"
                BorderBrush="#E5E7EB"
                BorderThickness="1"
                Padding="15">

            <ContentControl x:Name="MainArea"/>

        </Border>

    </Grid>

</UserControl>