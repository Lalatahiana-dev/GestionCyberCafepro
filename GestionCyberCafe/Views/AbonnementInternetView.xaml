<UserControl x:Class="Gestion_CyberCafe.Views.Abonnement.Pages.AbonnementInternetView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F9FAFB">

    <Grid Margin="15">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ================= TAB MENU ================= -->
        <Border Grid.Row="0"
                Background="White"
                CornerRadius="10"
                Padding="8"
                BorderBrush="#E5E7EB"
                BorderThickness="1">

            <Grid>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- FORFAIT -->
                <Button x:Name="BtnForfait"
                        Grid.Column="0"
                        Content="📦 FORFAIT"
                        Height="42"
                        Margin="6"
                        Background="#F3F4F6"
                        Foreground="#111827"
                        BorderThickness="0"
                        FontWeight="SemiBold"
                        Cursor="Hand"
                        Click="BtnForfait_Click">

                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="border"
                                                Background="{TemplateBinding Background}"
                                                CornerRadius="8"
                                                Padding="10">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>

                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="border"
                                                        Property="Background"
                                                        Value="#E5E7EB"/>
                                            </Trigger>

                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter TargetName="border"
                                                        Property="Background"
                                                        Value="#D1D5DB"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>

                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>

                </Button>

                <!-- ABONNEMENT LONG -->
                <Button x:Name="BtnAbonnementLong"
                        Grid.Column="1"
                        Content="📅 ABONNEMENT LONG"
                        Height="42"
                        Margin="6"
                        Background="#F3F4F6"
                        Foreground="#111827"
                        BorderThickness="0"
                        FontWeight="SemiBold"
                        Cursor="Hand"
                        Click="BtnAbonnementLong_Click">

                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="border"
                                                Background="{TemplateBinding Background}"
                                                CornerRadius="8"
                                                Padding="10">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>

                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="border"
                                                        Property="Background"
                                                        Value="#E5E7EB"/>
                                            </Trigger>

                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter TargetName="border"
                                                        Property="Background"
                                                        Value="#D1D5DB"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>

                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>

                </Button>

            </Grid>

        </Border>

        <!-- ================= CONTENT ================= -->
        <Border Grid.Row="1"
                Margin="0,12,0,0"
                Background="White"
                CornerRadius="10"
                Padding="15"
                BorderBrush="#E5E7EB"
                BorderThickness="1">

            <ContentControl x:Name="MainArea"/>

        </Border>

    </Grid>

</UserControl>