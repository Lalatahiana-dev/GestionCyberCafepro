<UserControl x:Class="Gestion_CyberCafe.Views.Abonnement.Pages.AbonnementLongView"
          xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
          xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
          xmlns:fa="http://schemas.fontawesome.io/icons/"
          Background="#F4F6F9">

    <Grid Margin="15">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.2*"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>

        <!-- ================= CLIENT ================= -->
        <Border Grid.Column="0"
            Background="White"
            CornerRadius="10"
            Padding="15"
            Margin="0,0,10,0"
            BorderBrush="#E5E7EB"
            BorderThickness="1">

            <StackPanel>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,15">

                    <fa:ImageAwesome Icon="User"
                                     Width="18"
                                     Foreground="#2563EB"
                                     Margin="0,0,8,0"/>

                    <TextBlock Text="CLIENT"
                               FontSize="18"
                               FontWeight="Bold"/>
                </StackPanel>

                <!-- SEARCH -->
                <StackPanel Orientation="Horizontal">

                    <fa:ImageAwesome Icon="Search"
                                     Width="14"
                                     Foreground="#6B7280"
                                     VerticalAlignment="Center"
                                     Margin="0,0,6,0"/>

                    <TextBlock Text="Recherche Client"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <TextBox x:Name="txtSearchClient"
                     Height="35"
                     Margin="0,5,0,10"
                     TextChanged="TxtSearchClient_TextChanged"/>

                <!-- LIST CLIENT -->
                <DataGrid x:Name="dgClients"
                      Height="200"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      SelectionChanged="DgClients_SelectionChanged">

                    <DataGrid.Columns>

                        <DataGridTextColumn Header="Nom" Binding="{Binding Nom}" Width="*" />
                        <DataGridTextColumn Header="Prénom" Binding="{Binding Prenom}" Width="*" />
                        <DataGridTextColumn Header="Téléphone" Binding="{Binding Telephone}" Width="*" />
                        <DataGridTextColumn Header="Adresse" Binding="{Binding Adresse}" Width="*" />

                        <DataGridTemplateColumn Header="Actions" Width="100">

                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>

                                    <StackPanel Orientation="Horizontal">

                                        <Button Width="30"
                                                Margin="2"
                                                Background="#FACC15"
                                                Click="BtnEditClient_Click">

                                            <fa:ImageAwesome Icon="Edit"
                                                             Width="12"
                                                             Foreground="Black"/>
                                        </Button>

                                        <Button Width="30"
                                                Margin="2"
                                                Background="#EF4444"
                                                Click="BtnDeleteClient_Click">

                                            <fa:ImageAwesome Icon="Trash"
                                                             Width="12"
                                                             Foreground="White"/>
                                        </Button>

                                    </StackPanel>

                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>

                        </DataGridTemplateColumn>

                    </DataGrid.Columns>

                </DataGrid>

                <Separator Margin="0,15"/>

                <!-- FORM CLIENT -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">

                    <fa:ImageAwesome Icon="UserPlus"
                                     Width="16"
                                     Foreground="#2563EB"
                                     Margin="0,0,6,0"/>

                    <TextBlock Text="CLIENT FORM"
                               FontSize="16"
                               FontWeight="Bold"/>
                </StackPanel>

                <TextBlock Text="Nom"/>
                <TextBox x:Name="txtNom" Height="35" Margin="0,5,0,10"/>

                <TextBlock Text="Prénom"/>
                <TextBox x:Name="txtPrenom" Height="35" Margin="0,5,0,10"/>

                <TextBlock Text="Téléphone"/>
                <TextBox x:Name="txtTelephone" Height="35" Margin="0,5,0,10"/>

                <TextBlock Text="Adresse"/>
                <TextBox x:Name="txtAdresse" Height="35" Margin="0,5,0,10"/>

                <StackPanel Orientation="Horizontal">

                    <Button Width="120"
                            Background="#2563EB"
                            Foreground="White"
                            Click="BtnAjouterClient_Click">

                        <StackPanel Orientation="Horizontal">
                            <fa:ImageAwesome Icon="Check"
                                             Width="12"
                                             Margin="0,0,6,0"/>
                            <TextBlock Text="Ajouter"/>
                        </StackPanel>

                    </Button>

                    <Button Width="120"
                            Margin="10,0,0,0"
                            Background="#FACC15"
                            Click="BtnUpdateClient_Click">

                        <StackPanel Orientation="Horizontal">
                            <fa:ImageAwesome Icon="Edit"
                                             Width="12"
                                             Margin="0,0,6,0"/>
                            <TextBlock Text="Modifier"/>
                        </StackPanel>

                    </Button>

                </StackPanel>

            </StackPanel>

        </Border>

        <!-- ================= ABONNEMENT LONG ================= -->
        <Border Grid.Column="1"
            Background="White"
            CornerRadius="10"
            Padding="15"
            BorderBrush="#E5E7EB"
            BorderThickness="1">

            <StackPanel>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,15">

                    <fa:ImageAwesome Icon="Calendar"
                                     Width="18"
                                     Foreground="#16A34A"
                                     Margin="0,0,8,0"/>

                    <TextBlock Text="ABONNEMENT LONG"
                               FontSize="18"
                               FontWeight="Bold"/>
                </StackPanel>

                <!-- CLIENT -->
                <TextBlock Text="Client sélectionné"/>

                <TextBox x:Name="txtClientSelectionne"
             Height="35"
             IsReadOnly="True"
             Background="#F3F4F6"
             Margin="0,5,0,15"/>

                <!-- TYPE ACCES -->
                <TextBlock Text="Type Accès"/>

                <ComboBox x:Name="cbTypeAcces"
              Height="35"
              Margin="0,5,0,15">

                    <ComboBoxItem Content="WIFI"/>
                    <ComboBoxItem Content="POSTE"/>
                    <ComboBoxItem Content="POSTE+WIFI"/>

                </ComboBox>

                <!-- APPAREILS -->
                <TextBlock Text="Nombre POSTE"/>

                <TextBox x:Name="txtNbPoste"
             Text="0"
             Height="35"
             Margin="0,5,0,10"
             TextChanged="TxtNbPoste_TextChanged"/>

                <TextBlock Text="Nombre WIFI"/>

                <TextBox x:Name="txtNbWifi"
             Text="0"
             Height="35"
             Margin="0,5,0,15"
             TextChanged="TxtNbWifi_TextChanged"/>

                <!-- FORFAIT -->
                <TextBlock Text="Forfait"/>

                <ComboBox x:Name="cbForfait"
                                 Height="35"
                                Margin="0,5,0,15"
                                SelectionChanged="CbForfait_SelectionChanged">

                    <ComboBoxItem Content="SEMAINE"/>
                    <ComboBoxItem Content="MOIS"/>
                    <ComboBoxItem Content="ANNEE"/>

                </ComboBox>

                <!-- EXPIRATION -->
                <TextBlock Text="Expiration prévue"/>

                <TextBox x:Name="txtExpiration"
             Height="35"
             IsReadOnly="True"
             Background="#F3F4F6"
             Margin="0,5,0,15"/>

                <!-- MONTANT -->
                <TextBlock Text="Montant total"/>

                <TextBlock x:Name="txtMontant"
               Text="0 Ar"
               FontSize="22"
               FontWeight="Bold"
               Foreground="#16A34A"
               Margin="0,5,0,20"/>

                <!-- BUTTON -->
                <Button Height="45"
            Background="#16A34A"
            Foreground="White"
            FontWeight="Bold"
            Click="BtnActiver_Click">

                    <StackPanel Orientation="Horizontal">
                        <fa:ImageAwesome Icon="Rocket"
                                         Width="14"
                                         Margin="0,0,6,0"/>
                        <TextBlock Text="Activer Abonnement"/>
                    </StackPanel>

                </Button>

            </StackPanel>

        </Border>

    </Grid>

</UserControl>