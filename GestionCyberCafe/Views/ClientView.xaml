<UserControl x:Class="Gestion_CyberCafe.Views.Client.ClientView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F4F6F9">

    <Grid Margin="15">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="2*"/>
        </Grid.ColumnDefinitions>

        <!-- ================= FORM AJOUT ================= -->
        <Border Grid.Column="0"
                Background="White"
                Padding="15"
                CornerRadius="10"
                BorderBrush="#E5E7EB"
                BorderThickness="1">

            <StackPanel>

                <TextBlock Text="👤 AJOUT CLIENT"
                           FontSize="18"
                           FontWeight="Bold"
                           Margin="0,0,0,15"/>

                <!-- NOM -->
                <TextBlock Text="Nom"/>
                <TextBox x:Name="txtNom"
                         Height="35"
                         Margin="0,5,0,10"/>

                <!-- PRENOM -->
                <TextBlock Text="Prénom"/>
                <TextBox x:Name="txtPrenom"
                         Height="35"
                         Margin="0,5,0,10"/>

                <!-- TELEPHONE -->
                <TextBlock Text="Téléphone"/>
                <TextBox x:Name="txtTelephone"
                         Height="35"
                         Margin="0,5,0,10"/>

                <!-- ADRESSE -->
                <TextBlock Text="Adresse"/>
                <TextBox x:Name="txtAdresse"
                         Height="35"
                         Margin="0,5,0,10"/>

                <!-- BUTTON SAVE -->
                <Button Content="✔ AJOUTER CLIENT"
                        Height="40"
                        Background="#2563EB"
                        Foreground="White"
                        Margin="0,15,0,0"
                        Click="BtnSave_Click"/>

                <!-- RESET -->
                <Button Content="🔄 RESET"
                        Height="35"
                        Background="#6B7280"
                        Foreground="White"
                        Margin="0,10,0,0"
                        Click="BtnReset_Click"/>

            </StackPanel>

        </Border>

        <!-- ================= LIST CLIENTS ================= -->
        <Border Grid.Column="1"
                Background="White"
                Padding="15"
                Margin="10,0,0,0"
                CornerRadius="10"
                BorderBrush="#E5E7EB"
                BorderThickness="1">

            <StackPanel>

                <TextBlock Text="📋 LISTE CLIENTS"
                           FontSize="18"
                           FontWeight="Bold"
                           Margin="0,0,0,10"/>

                <!-- DATA GRID -->
                <DataGrid x:Name="dgClients"
                          AutoGenerateColumns="True"
                          Height="450"
                          IsReadOnly="True"/>

            </StackPanel>

        </Border>

    </Grid>

</UserControl>