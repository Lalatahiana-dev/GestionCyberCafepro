<UserControl x:Class="Gestion_CyberCafe.Views.Abonnement.Pages.ForfaitView"
          xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
          xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
          xmlns:fa="http://schemas.fontawesome.io/icons/"
          Background="#F4F6F9">

    <Grid Margin="15">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.2*"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>

        <!-- ================= CLIENT ================= -->
        <Border Grid.Column="0"
        Background="White"
        CornerRadius="10"
        Padding="15"
        Margin="0,0,10,0"
        BorderBrush="#E5E7EB"
        BorderThickness="1">

            <StackPanel>

                <!-- TITLE -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,15">

                    <fa:ImageAwesome Icon="User"
                                     Width="18"
                                     Foreground="#2563EB"
                                     Margin="0,0,8,0"/>

                    <TextBlock Text="CLIENT"
                               FontSize="18"
                               FontWeight="Bold"/>
                </StackPanel>

                <!-- SEARCH -->
                <StackPanel Orientation="Horizontal">

                    <fa:ImageAwesome Icon="Search"
                                     Width="14"
                                     Foreground="#6B7280"
                                     Margin="0,0,6,0"
                                     VerticalAlignment="Center"/>

                    <TextBlock Text="Recherche Client"/>
                </StackPanel>

                <TextBox x:Name="txtSearchClient"
                 Height="35"
                 Margin="0,5,0,10"
                 TextChanged="TxtSearchClient_TextChanged"/>

                <!-- LIST CLIENT -->
                <DataGrid x:Name="dgClients"
                  Height="200"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  SelectionChanged="DgClients_SelectionChanged">

                    <DataGrid.Columns>

                        <DataGridTextColumn Header="Nom" Binding="{Binding Nom}" Width="*" />
                        <DataGridTextColumn Header="Prénom" Binding="{Binding Prenom}" Width="*" />
                        <DataGridTextColumn Header="Téléphone" Binding="{Binding Telephone}" Width="*" />
                        <DataGridTextColumn Header="Adresse" Binding="{Binding Adresse}" Width="*" />

                        <DataGridTemplateColumn Header="Actions" Width="100">

                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>

                                    <StackPanel Orientation="Horizontal">

                                        <Button Width="30"
                                                Margin="2"
                                                Background="#FACC15"
                                                Click="BtnEditClient_Click">

                                            <fa:ImageAwesome Icon="edit"
                                                             Width="12"
                                                             Foreground="Black"/>
                                        </Button>

                                        <Button Width="30"
                                                Margin="2"
                                                Background="#EF4444"
                                                Click="BtnDeleteClient_Click">

                                            <fa:ImageAwesome Icon="Trash"
                                                             Width="12"
                                                             Foreground="White"/>
                                        </Button>

                                    </StackPanel>

                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>

                        </DataGridTemplateColumn>

                    </DataGrid.Columns>

                </DataGrid>

                <Separator Margin="0,15"/>

                <!-- FORM -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">

                    <fa:ImageAwesome Icon="UserPlus"
                                     Width="16"
                                     Foreground="#2563EB"
                                     Margin="0,0,6,0"/>

                    <TextBlock Text="FORM CLIENT"
                               FontSize="16"
                               FontWeight="Bold"/>
                </StackPanel>

                <TextBlock>
                    <StackPanel Orientation="Horizontal">
                        <fa:ImageAwesome Icon="User" Width="12" Margin="0,0,5,0"/>
                        <TextBlock Text="Nom"/>
                    </StackPanel>
                </TextBlock>
                <TextBox x:Name="txtNom" Height="35" Margin="0,5,0,10"/>

                <TextBlock>
                    <StackPanel Orientation="Horizontal">
                        <fa:ImageAwesome Icon="User" Width="12" Margin="0,0,5,0"/>
                        <TextBlock Text="Prénom"/>
                    </StackPanel>
                </TextBlock>
                <TextBox x:Name="txtPrenom" Height="35" Margin="0,5,0,10"/>

                <TextBlock>
                    <StackPanel Orientation="Horizontal">
                        <fa:ImageAwesome Icon="Phone" Width="12" Margin="0,0,5,0"/>
                        <TextBlock Text="Téléphone"/>
                    </StackPanel>
                </TextBlock>
                <TextBox x:Name="txtTelephone" Height="35" Margin="0,5,0,10"/>

                <TextBlock>
                    <StackPanel Orientation="Horizontal">
                        <fa:ImageAwesome Icon="MapMarker" Width="12" Margin="0,0,5,0"/>
                        <TextBlock Text="Adresse"/>
                    </StackPanel>
                </TextBlock>
                <TextBox x:Name="txtAdresse" Height="35" Margin="0,5,0,10"/>

                <!-- BUTTONS -->
                <StackPanel Orientation="Horizontal">

                    <Button Width="120"
                            Background="#2563EB"
                            Foreground="White"
                            Click="BtnAjouterClient_Click">

                        <StackPanel Orientation="Horizontal">
                            <fa:ImageAwesome Icon="Check"
                                             Width="12"
                                             Margin="0,0,6,0"/>
                            <TextBlock Text="Ajouter"/>
                        </StackPanel>

                    </Button>

                    <Button Width="120"
                            Margin="10,0,0,0"
                            Background="#FACC15"
                            Click="BtnUpdateClient_Click">

                        <StackPanel Orientation="Horizontal">
                            <fa:ImageAwesome Icon="edit"
                                             Width="12"
                                             Margin="0,0,6,0"/>
                            <TextBlock Text="Modifier"/>
                        </StackPanel>

                    </Button>

                    <Button Width="100"
                            Margin="10,0,0,0"
                            Background="#6B7280"
                            Foreground="White"
                            Click="BtnResetClient_Click">

                        <StackPanel Orientation="Horizontal">
                            <fa:ImageAwesome Icon="RotateRight"
                                             Width="12"
                                             Margin="0,0,6,0"/>
                            <TextBlock Text="Reset"/>
                        </StackPanel>

                    </Button>

                </StackPanel>

            </StackPanel>

        </Border>

        <!-- ================= FORFAIT ================= -->
        <Border Grid.Column="1"
        Background="White"
        CornerRadius="10"
        Padding="15"
        BorderBrush="#E5E7EB"
        BorderThickness="1">

            <StackPanel>

                <!-- TITLE -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,15">

                    <fa:ImageAwesome Icon="Archive"
                                     Width="18"
                                     Foreground="#16A34A"
                                     Margin="0,0,8,0"/>

                    <TextBlock Text="FORFAIT INTERNET"
                               FontSize="18"
                               FontWeight="Bold"/>
                </StackPanel>

                <!-- CLIENT -->
                <TextBlock>
                    <StackPanel Orientation="Horizontal">
                        <fa:ImageAwesome Icon="User" Width="12" Margin="0,0,5,0"/>
                        <TextBlock Text="Client sélectionné"/>
                    </StackPanel>
                </TextBlock>

                <TextBox x:Name="txtClientSelectionne"
                 Height="35"
                 IsReadOnly="True"
                 Background="#F3F4F6"
                 Margin="0,5,0,15"/>

                <!-- TYPE ACCES -->
                <TextBlock>
                    <StackPanel Orientation="Horizontal">
                        <fa:ImageAwesome Icon="Wifi" Width="12" Margin="0,0,5,0"/>
                        <TextBlock Text="Type Accès"/>
                    </StackPanel>
                </TextBlock>

                <ComboBox x:Name="cbTypeAcces"
                  Height="35"
                  Margin="0,5,0,15">

                    <ComboBoxItem Content="WIFI"/>
                    <ComboBoxItem Content="POSTE"/>
                    <ComboBoxItem Content="POSTE+WIFI"/>

                </ComboBox>

                <!-- FORFAIT -->
                <TextBlock>
                    <StackPanel Orientation="Horizontal">
                        <fa:ImageAwesome Icon="Calendar" Width="12" Margin="0,0,5,0"/>
                        <TextBlock Text="Type Forfait"/>
                    </StackPanel>
                </TextBlock>

                <ComboBox x:Name="cbForfait"
                  Height="35"
                  Margin="0,5,0,15"
                  SelectionChanged="CbForfait_SelectionChanged">

                    <ComboBoxItem Content="DEMI_JOURNEE"/>
                    <ComboBoxItem Content="NUIT"/>
                    <ComboBoxItem Content="JOURNEE"/>

                </ComboBox>

                <!-- APPAREILS -->
                <TextBlock>
                    <StackPanel Orientation="Horizontal">
                        <fa:ImageAwesome Icon="Desktop" Width="12" Margin="0,0,5,0"/>
                        <TextBlock Text="Nombre poste"/>
                    </StackPanel>
                </TextBlock>

                <TextBox x:Name="txtNbPoste"
                    Text="0"
                    Height="35"
                    Margin="0,5,0,10"
                    TextChanged="TxtNbPoste_TextChanged"/>

                <TextBlock>
                    <StackPanel Orientation="Horizontal">
                        <fa:ImageAwesome Icon="Wifi" Width="12" Margin="0,0,5,0"/>
                        <TextBlock Text="Nombre wifi"/>
                    </StackPanel>
                </TextBlock>

                <TextBox x:Name="txtNbWifi"
                    Text="0"
                    Height="35"
                    Margin="0,5,0,15"
                    TextChanged="TxtNbWifi_TextChanged"/>

                <!-- DATES -->
                <TextBlock>
                    <StackPanel Orientation="Horizontal">
                        <fa:ImageAwesome Icon="Calendar" Width="12" Margin="0,0,5,0"/>
                        <TextBlock Text="Date Début"/>
                    </StackPanel>
                </TextBlock>

                <TextBox x:Name="txtDateDebut"
                 Height="35"
                 IsReadOnly="True"
                 Background="#F3F4F6"
                 Margin="0,5,0,15"/>

                <TextBlock>
                    <StackPanel Orientation="Horizontal">
                        <fa:ImageAwesome Icon="Calendar" Width="12" Margin="0,0,5,0"/>
                        <TextBlock Text="Expiration"/>
                    </StackPanel>
                </TextBlock>

                <TextBox x:Name="txtExpiration"
                 Height="35"
                 IsReadOnly="True"
                 Background="#F3F4F6"
                 Margin="0,5,0,15"/>

                <!-- MONTANT -->
                <TextBlock>
                    <StackPanel Orientation="Horizontal">
                        <fa:ImageAwesome Icon="Money"
                                         Width="12"
                                         Margin="0,0,5,0"/>
                        <TextBlock Text="Montant"/>
                    </StackPanel>
                </TextBlock>

                <TextBlock x:Name="txtMontant"
                   Text="0 Ar"
                   FontSize="22"
                   FontWeight="Bold"
                   Foreground="#16A34A"
                   Margin="0,5,0,20"/>

                <!-- BUTTON -->
                <Button Height="45"
                Background="#16A34A"
                Foreground="White"
                FontWeight="Bold"
                Click="BtnActiver_Click">

                    <StackPanel Orientation="Horizontal">
                        <fa:ImageAwesome Icon="Rocket"
                                         Width="14"
                                         Margin="0,0,6,0"/>
                        <TextBlock Text="Activer Forfait"/>
                    </StackPanel>

                </Button>

            </StackPanel>

        </Border>

    </Grid>

</UserControl>