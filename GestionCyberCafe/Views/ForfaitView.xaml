<UserControl x:Class="Gestion_CyberCafe.Views.Abonnement.Pages.ForfaitView"
          xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
          xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
          Background="#F4F6F9">


    <Grid Margin="15">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.2*"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>

        <!-- ================= CLIENT ================= -->
        <Border Grid.Column="0"
        Background="White"
        CornerRadius="10"
        Padding="15"
        Margin="0,0,10,0"
        BorderBrush="#E5E7EB"
        BorderThickness="1">

            <StackPanel>

                <!-- TITLE -->
                <TextBlock Text="👤 CLIENT"
                   FontSize="18"
                   FontWeight="Bold"
                   Margin="0,0,0,15"/>

                <!-- ================= SEARCH ================= -->
                <TextBlock Text="Recherche Client"/>

                <TextBox x:Name="txtSearchClient"
                 Height="35"
                 Margin="0,5,0,10"
                 TextChanged="TxtSearchClient_TextChanged"/>

                <!-- ================= LIST CLIENT ================= -->
                <DataGrid x:Name="dgClients"
                  Height="200"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  SelectionChanged="DgClients_SelectionChanged">

                    <DataGrid.Columns>

                        <DataGridTextColumn Header="Nom" Binding="{Binding Nom}" Width="*" />
                        <DataGridTextColumn Header="Prénom" Binding="{Binding Prenom}" Width="*" />
                        <DataGridTextColumn Header="Téléphone" Binding="{Binding Telephone}" Width="*" />
                        <DataGridTextColumn Header="Adresse" Binding="{Binding Adresse}" Width="*" />

                        <!-- ACTIONS -->
                        <DataGridTemplateColumn Header="Actions" Width="100">

                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>

                                    <StackPanel Orientation="Horizontal">

                                        <!-- EDIT -->
                                        <Button Content="✏"
                                        Width="30"
                                        Margin="2"
                                        Background="#FACC15"
                                        Click="BtnEditClient_Click"/>

                                        <!-- DELETE -->
                                        <Button Content="🗑"
                                        Width="30"
                                        Margin="2"
                                        Background="#EF4444"
                                        Foreground="White"
                                        Click="BtnDeleteClient_Click"/>

                                    </StackPanel>

                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>

                        </DataGridTemplateColumn>

                    </DataGrid.Columns>

                </DataGrid>

                <Separator Margin="0,15"/>

                <!-- ================= FORM ================= -->
                <TextBlock Text="➕ / ✏ CLIENT"
                   FontSize="16"
                   FontWeight="Bold"
                   Margin="0,0,0,10"/>

                <TextBlock Text="Nom"/>
                <TextBox x:Name="txtNom"
                 Height="35"
                 Margin="0,5,0,10"/>

                <TextBlock Text="Prénom"/>
                <TextBox x:Name="txtPrenom"
                 Height="35"
                 Margin="0,5,0,10"/>

                <TextBlock Text="Téléphone"/>
                <TextBox x:Name="txtTelephone"
                 Height="35"
                 Margin="0,5,0,10"/>

                <TextBlock Text="Adresse"/>
                <TextBox x:Name="txtAdresse"
                 Height="35"
                 Margin="0,5,0,10"/>

                <!-- BUTTONS -->
                <StackPanel Orientation="Horizontal">

                    <Button Content="✔ Ajouter"
                    Width="120"
                    Height="40"
                    Margin="0,0,10,0"
                    Background="#2563EB"
                    Foreground="White"
                    Click="BtnAjouterClient_Click"/>

                    <Button Content="💾 Modifier"
                    Width="120"
                    Height="40"
                    Margin="0,0,10,0"
                    Background="#FACC15"
                    Click="BtnUpdateClient_Click"/>

                    <Button Content="🔄 Reset"
                    Width="100"
                    Height="40"
                    Background="#6B7280"
                    Foreground="White"
                    Click="BtnResetClient_Click"/>

                </StackPanel>

            </StackPanel>

        </Border>

        <!-- ================= FORFAIT ================= -->
        <Border Grid.Column="1"
        Background="White"
        CornerRadius="10"
        Padding="15"
        BorderBrush="#E5E7EB"
        BorderThickness="1">

            <StackPanel>

                <TextBlock Text="📦 FORFAIT INTERNET"
                   FontSize="18"
                   FontWeight="Bold"
                   Margin="0,0,0,15"/>

                <!-- ================= CLIENT ================= -->
                <TextBlock Text="Client Sélectionné"/>

                <TextBox x:Name="txtClientSelectionne"
                 Height="35"
                 IsReadOnly="True"
                 Background="#F3F4F6"
                 Margin="0,5,0,15"/>

                <!-- ================= TYPE ACCES ================= -->
                <TextBlock Text="Type Accès"/>

                <ComboBox x:Name="cbTypeAcces"
                  Height="35"
                  Margin="0,5,0,15">

                    <ComboBoxItem Content="WIFI"/>
                    <ComboBoxItem Content="POSTE"/>
                    <ComboBoxItem Content="POSTE+WIFI"/>
       

                </ComboBox>

                <!-- ================= FORFAIT ================= -->
                <TextBlock Text="Type Forfait"/>

                <ComboBox x:Name="cbForfait"
                  Height="35"
                  Margin="0,5,0,15"
                  SelectionChanged="CbForfait_SelectionChanged">

                    <ComboBoxItem Content="DEMI_JOURNEE"/>
                    <ComboBoxItem Content="NUIT"/>
                    <ComboBoxItem Content="JOURNEE"/>

                </ComboBox>

                <!-- ================= NB APPAREILS ================= -->
                <TextBlock Text="Nombre poste"/>
                <TextBox x:Name="txtNbPoste"
                    Text="0"
                    Height="35"
                    Margin="0,5,0,10"
                    TextChanged="TxtNbPoste_TextChanged"/>
                <TextBlock Text="Nombre wifi"/>
                <TextBox x:Name="txtNbWifi"
                            Text="0"
                            Height="35"
                            Margin="0,5,0,15"
                            TextChanged="TxtNbWifi_TextChanged"/>
                <!-- ================= DATES ================= -->
                <TextBlock Text="Date Début"/>

                <TextBox x:Name="txtDateDebut"
                 Height="35"
                 IsReadOnly="True"
                 Background="#F3F4F6"
                 Margin="0,5,0,15"/>

                <TextBlock Text="Expiration"/>

                <TextBox x:Name="txtExpiration"
                 Height="35"
                 IsReadOnly="True"
                 Background="#F3F4F6"
                 Margin="0,5,0,15"/>

                <!-- ================= MONTANT ================= -->
                <TextBlock Text="Montant"/>

                <TextBlock x:Name="txtMontant"
                   Text="0 Ar"
                   FontSize="22"
                   FontWeight="Bold"
                   Foreground="#16A34A"
                   Margin="0,5,0,20"/>

                <!-- ================= BUTTON ================= -->
                <Button Content="🚀 Activer Forfait"
                Height="45"
                Background="#16A34A"
                Foreground="White"
                FontWeight="Bold"
                Click="BtnActiver_Click"/>

            </StackPanel>

        </Border>
    </Grid>
 

</UserControl>
