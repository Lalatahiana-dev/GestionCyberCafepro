<UserControl x:Class="Gestion_CyberCafe.Views.Poste.GestionPosteView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:fa="http://schemas.fontawesome.io/icons/"
             Background="#F5F7FA">

    <Grid Margin="20">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="340"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ================= LEFT FORM ================= -->
        <Border Grid.Column="0"
                Background="White"
                CornerRadius="14"
                Padding="20"
                BorderBrush="#E5E7EB"
                BorderThickness="1">

            <Border.Effect>
                <DropShadowEffect BlurRadius="15" Opacity="0.08"/>
            </Border.Effect>

            <StackPanel>

                <!-- TITLE -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,20">

                    <fa:ImageAwesome Icon="Desktop"
                                     Width="18"
                                     Height="18"
                                     Foreground="#2563EB"
                                     Margin="0,0,10,0"/>

                    <TextBlock Text="Gestion des Postes"
                               FontSize="22"
                               FontWeight="SemiBold"
                               Foreground="#111827"/>
                </StackPanel>

                <!-- NOM -->
                <TextBlock Text="Nom Poste" Foreground="#6B7280"/>
                <TextBox x:Name="txtNomPoste"
                         Height="40"
                         Margin="0,5,0,12"/>

                <!-- DESCRIPTION -->
                <TextBlock Text="Description" Foreground="#6B7280"/>
                <TextBox x:Name="txtDescription"
                         Height="40"
                         Margin="0,5,0,12"/>

                <!-- STATUT -->
                <TextBlock Text="Statut" Foreground="#6B7280"/>
                <ComboBox x:Name="cbStatut"
                          Height="40"
                          Margin="0,5,0,20">

                    <ComboBoxItem Content="LIBRE"/>
                    <ComboBoxItem Content="OCCUPE"/>
                    <ComboBoxItem Content="MAINTENANCE"/>

                </ComboBox>

                <!-- BUTTONS PRO -->
                <StackPanel>

                    <!-- AJOUT -->
                    <Button Height="40"
                            Background="#16A34A"
                            Foreground="White"
                            BorderThickness="0"
                            Margin="0,0,0,8"
                            Click="BtnAjouter_Click">

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">

                            <fa:ImageAwesome Icon="Plus"
                                             Width="14"
                                             Height="14"
                                             Margin="0,0,8,0"/>

                            <TextBlock Text="Ajouter"/>
                        </StackPanel>

                    </Button>

                    <!-- MODIFIER -->
                    <Button Height="40"
                            Background="#2563EB"
                            Foreground="White"
                            BorderThickness="0"
                            Margin="0,0,0,8"
                            Click="BtnModifier_Click">

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">

                            <fa:ImageAwesome Icon="Edit"
                                             Width="14"
                                             Height="14"
                                             Margin="0,0,8,0"/>

                            <TextBlock Text="Modifier"/>
                        </StackPanel>

                    </Button>

                    <!-- SUPPRIMER -->
                    <Button Height="40"
                            Background="#DC2626"
                            Foreground="White"
                            BorderThickness="0"
                            Click="BtnSupprimer_Click">

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">

                            <fa:ImageAwesome Icon="Trash"
                                             Width="14"
                                             Height="14"
                                             Margin="0,0,8,0"/>

                            <TextBlock Text="Supprimer"/>
                        </StackPanel>

                    </Button>

                </StackPanel>

            </StackPanel>

        </Border>

        <!-- ================= RIGHT LIST ================= -->
        <Border Grid.Column="1"
                Background="White"
                CornerRadius="14"
                Padding="15"
                BorderBrush="#E5E7EB"
                BorderThickness="1"
                Margin="15,0,0,0">

            <Border.Effect>
                <DropShadowEffect BlurRadius="15" Opacity="0.08"/>
            </Border.Effect>

            <Grid>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- HEADER -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">

                    <fa:ImageAwesome Icon="List"
                                     Width="16"
                                     Height="16"
                                     Foreground="#111827"
                                     Margin="0,0,8,0"/>

                    <TextBlock Text="Liste des postes"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="#111827"/>
                </StackPanel>

                <!-- DATAGRID -->
                <DataGrid Grid.Row="1"
                          x:Name="dgPostes"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          GridLinesVisibility="None"
                          HeadersVisibility="Column"
                          RowHeight="42"
                          Background="White">

                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#F3F4F6"/>
                            <Setter Property="Foreground" Value="#111827"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Height" Value="42"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>

                    <DataGrid.Columns>

                        <DataGridTextColumn Header="ID"
                                            Binding="{Binding IdPoste}"
                                            Width="70"/>

                        <DataGridTextColumn Header="Nom"
                                            Binding="{Binding NomPoste}"
                                            Width="*"/>

                        <DataGridTextColumn Header="Description"
                                            Binding="{Binding Description}"
                                            Width="2*"/>

                        <DataGridTextColumn Header="Statut"
                                            Binding="{Binding Statut}"
                                            Width="140"/>

                    </DataGrid.Columns>

                </DataGrid>

            </Grid>

        </Border>

    </Grid>

</UserControl>