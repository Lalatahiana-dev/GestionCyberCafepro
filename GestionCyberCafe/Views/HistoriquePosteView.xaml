<UserControl x:Class="Gestion_CyberCafe.Views.Poste.HistoriquePosteView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:fa="http://schemas.fontawesome.io/icons/"
             Background="#F5F7FA">

    <Grid Margin="15">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ================= FILTER BAR ================= -->
        <Border Grid.Row="0"
                Background="White"
                CornerRadius="14"
                Padding="15"
                Margin="0,0,0,12"
                BorderBrush="#E5E7EB"
                BorderThickness="1">

            <StackPanel>

                <!-- TITLE -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,15">

                    <fa:ImageAwesome Icon="History"
                                     Foreground="#2563EB"
                                     Width="18"
                                     Margin="0,0,8,0"/>

                    <TextBlock Text="Historique des Sessions Poste"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="#111827"/>
                </StackPanel>

                <!-- FILTER ROW -->
                <UniformGrid Columns="5">

                    <!-- SEARCH -->
                    <Border Background="#F9FAFB"
                            CornerRadius="10"
                            Padding="5"
                            Margin="5">

                        <Grid Height="36">

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="35"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <fa:ImageAwesome Icon="Search"
                                             Width="14"
                                             Foreground="#6B7280"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Center"/>

                            <TextBox x:Name="txtSearch"
                                     Grid.Column="1"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     VerticalContentAlignment="Center"/>

                        </Grid>

                    </Border>

                    <!-- DATE DEBUT -->
                    <StackPanel Margin="5">
                        <TextBlock Text="Date début"
                                   Foreground="#6B7280"/>
                        <DatePicker x:Name="dpDebut"
                                    Height="36"/>
                    </StackPanel>

                    <!-- DATE FIN -->
                    <StackPanel Margin="5">
                        <TextBlock Text="Date fin"
                                   Foreground="#6B7280"/>
                        <DatePicker x:Name="dpFin"
                                    Height="36"/>
                    </StackPanel>

                    <!-- BTN SEARCH -->
                    <Button Background="#2563EB"
                            Foreground="White"
                            BorderThickness="0"
                            Height="36"
                            Margin="5"
                            Click="BtnRechercher_Click">

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">

                            <fa:ImageAwesome Icon="Search"
                                             Width="12"
                                             Margin="0,0,6,0"/>

                            <TextBlock Text="Rechercher"/>
                        </StackPanel>

                    </Button>

                    <!-- BTN RESET -->
                    <Button Background="#6B7280"
                            Foreground="White"
                            BorderThickness="0"
                            Height="36"
                            Margin="5"
                            Click="BtnReset_Click">

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">

                            <fa:ImageAwesome Icon="RotateRight"
                                             Width="12"
                                             Margin="0,0,6,0"/>

                            <TextBlock Text="Reset"/>
                        </StackPanel>

                    </Button>

                    

                </UniformGrid>

            </StackPanel>

        </Border>

        <!-- ================= TABLE ================= -->
        <Border Grid.Row="1"
                Background="White"
                CornerRadius="14"
                Padding="10"
                BorderBrush="#E5E7EB"
                BorderThickness="1">

            <DataGrid x:Name="dgHistorique"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      GridLinesVisibility="None"
                      RowHeight="40"
                      HeadersVisibility="Column">

                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#F3F4F6"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="Height" Value="42"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>

                <DataGrid.Columns>

                    <DataGridTextColumn Header="Client" Binding="{Binding NomClient}" Width="*"/>
                    <DataGridTextColumn Header="Poste" Binding="{Binding NomPoste}" Width="120"/>
                    <DataGridTextColumn Header="Début" Binding="{Binding HeureDebut}" Width="140"/>
                    <DataGridTextColumn Header="Fin" Binding="{Binding HeureFin}" Width="140"/>
                    <DataGridTextColumn Header="Durée" Binding="{Binding DureeMinutes}" Width="100"/>
                    <DataGridTextColumn Header="Montant" Binding="{Binding MontantTotal}" Width="110"/>
                    <DataGridTextColumn Header="Statut" Binding="{Binding Statut}" Width="100"/>

                    <!-- ACTION -->
                    <DataGridTemplateColumn Header="Action" Width="90">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>

                                <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center">

                                    <Button Width="32"
                        Height="32"
                        Margin="2"
                        Background="#FEE2E2"
                        BorderThickness="0"
                        Cursor="Hand"
                        ToolTip="Supprimer"
                        Click="BtnDelete_Click">

                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="bd"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="6">

                                                    <fa:ImageAwesome Icon="Trash"
                                                 Width="12"
                                                 Foreground="#DC2626"
                                                 HorizontalAlignment="Center"
                                                 VerticalAlignment="Center"/>
                                                </Border>

                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="bd"
                                            Property="Background"
                                            Value="#FCA5A5"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>

                                    </Button>

                                </StackPanel>

                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>

            </DataGrid>

        </Border>

    </Grid>

</UserControl>