<Window x:Class="Gestion_CyberCafe.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Login"
        Height="420"
        Width="420"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Grid Background="#0B1220">

        <!-- Card -->
        <Border Width="320"
                Padding="25"
                Background="#111827"
                CornerRadius="15"
                VerticalAlignment="Center"
                HorizontalAlignment="Center"
                BorderBrush="#1F2937"
                BorderThickness="1">

            <Border.Effect>
                <DropShadowEffect BlurRadius="20"
                                  ShadowDepth="0"
                                  Opacity="0.4"/>
            </Border.Effect>

            <StackPanel>

                <!-- Title -->
                <TextBlock Text="🔐 CyberCafe Login"
                           FontSize="22"
                           FontWeight="Bold"
                           Foreground="White"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,20"/>

                <!-- Username -->
                <TextBlock Text="Username"
                           Foreground="#9CA3AF"
                           Margin="0,0,0,5"/>

                <Border Background="#0F172A"
                        CornerRadius="8"
                        Padding="8"
                        BorderBrush="#1F2937"
                        BorderThickness="1">
                    <TextBox x:Name="txtUsername"
                             Background="Transparent"
                             BorderThickness="0"
                             Foreground="White"
                             Height="30"
                             FontSize="14"/>
                </Border>

                <!-- Password -->
                <TextBlock Text="Password"
                           Foreground="#9CA3AF"
                           Margin="0,15,0,5"/>

                <Border Background="#0F172A"
                        CornerRadius="8"
                        Padding="8"
                        BorderBrush="#1F2937"
                        BorderThickness="1">
                    <PasswordBox x:Name="txtPassword"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Foreground="White"
                                 Height="30"
                                 FontSize="14"/>
                </Border>

                <!-- Button -->
                <Button Content="Se connecter"
                        Height="42"
                        Margin="0,25,0,0"
                        Background="#2563EB"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="BtnLogin_Click">

                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#2563EB"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="8">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>

                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#1D4ED8"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>

                </Button>

            </StackPanel>
        </Border>

    </Grid>
</Window>