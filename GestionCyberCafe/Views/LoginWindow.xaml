<Window x:Class="Gestion_CyberCafe.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:fa="http://schemas.fontawesome.io/icons/"
        Title="Login"
        Height="500"
        Width="450"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Grid Background="#0B1220">

        <!-- CARD -->
        <Border Width="340"
                Padding="25"
                Background="#111827"
                CornerRadius="15"
                VerticalAlignment="Center"
                HorizontalAlignment="Center"
                BorderBrush="#1F2937"
                BorderThickness="1">

            <StackPanel>

                <!-- TITLE -->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Margin="0,0,0,25">

                    <fa:ImageAwesome Icon="Lock"
                                     Width="20"
                                     Foreground="White"
                                     Margin="0,0,8,0"/>

                    <TextBlock Text="CyberCafe Login"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="White"/>
                </StackPanel>

                <!-- USERNAME -->
                <TextBlock Text="Username"
                           Foreground="#9CA3AF"/>

                <Border Background="#0F172A"
                        CornerRadius="8"
                        Padding="8"
                        BorderBrush="#1F2937"
                        BorderThickness="1">

                    <StackPanel Orientation="Horizontal">

                        <fa:ImageAwesome Icon="User"
                                         Width="14"
                                         Foreground="#9CA3AF"
                                         Margin="0,0,8,0"/>

                        <TextBox x:Name="txtUsername"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Foreground="White"
                                 Width="220"/>
                    </StackPanel>

                </Border>

                <!-- PASSWORD -->
                <TextBlock Text="Password"
                           Foreground="#9CA3AF"
                           Margin="0,15,0,5"/>

                <Border Background="#0F172A"
                        CornerRadius="8"
                        Padding="8"
                        BorderBrush="#1F2937"
                        BorderThickness="1">

                    <Grid>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- PASSWORD HIDDEN -->
                        <PasswordBox x:Name="txtPassword"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Foreground="White"/>

                        <!-- PASSWORD VISIBLE -->
                        <TextBox x:Name="txtPasswordVisible"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Foreground="White"
                                 Visibility="Collapsed"/>

                        <!-- EYE -->
                        <Button Grid.Column="1"
                                Width="35"
                                Background="Transparent"
                                BorderThickness="0"
                                Click="TogglePassword_Click">

                            <fa:ImageAwesome x:Name="eyeIcon"
                                             Icon="Eye"
                                             Width="14"
                                             Foreground="#9CA3AF"/>
                        </Button>

                    </Grid>

                </Border>

                <!-- LOGIN BUTTON -->
                <Button x:Name="btnLogin"
                        Height="42"
                        Margin="0,25,0,0"
                        Background="#2563EB"
                        Foreground="White"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="BtnLogin_Click">

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">

                        <fa:ImageAwesome Icon="ArrowRight"
                                         Width="14"
                                         Foreground="White"
                                         Margin="0,0,8,0"/>

                        <TextBlock Text="Se connecter"/>
                    </StackPanel>
                </Button>

                <!-- LOADING -->
                <StackPanel x:Name="loadingPanel"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Margin="0,15,0,0"
                            Visibility="Collapsed">

                    <ProgressBar IsIndeterminate="True"
                                 Width="120"
                                 Height="6"/>

                    <TextBlock Text="Connexion..."
                               Foreground="#9CA3AF"
                               Margin="10,0,0,0"/>
                </StackPanel>

            </StackPanel>
        </Border>

    </Grid>
</Window>