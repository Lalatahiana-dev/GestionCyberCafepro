<Window x:Class="Gestion_CyberCafe.Views.ModifierAbonnementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Modifier Abonnement"
        Height="350"
        Width="400">

    <StackPanel Margin="15">

        <TextBlock Text="Nombre Poste"/>
        <TextBox x:Name="txtPoste" Margin="0,5,0,10"/>

        <TextBlock Text="Nombre Wifi"/>
        <TextBox x:Name="txtWifi" Margin="0,5,0,10"/>

        <Button Content="💾 Sauvegarder"
                Height="40"
                Background="#2563EB"
                Foreground="White"
                Click="BtnSave_Click"/>

    </StackPanel>

</Window>