<UserControl x:Class="Gestion_CyberCafe.Views.Poste.MonitoringPosteView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:fa="http://schemas.fontawesome.io/icons/"
             Background="#F5F7FA">

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ================= TITLE ================= -->
        <StackPanel Orientation="Horizontal" Margin="0,0,0,15">

            <fa:ImageAwesome Icon="Desktop"
                             Foreground="#2563EB"
                             Width="18"
                             Margin="0,0,8,0"/>

            <TextBlock Text="Monitoring CyberCafé"
                       FontSize="22"
                       FontWeight="SemiBold"
                       Foreground="#111827"/>
        </StackPanel>

        <!-- ================= STATS ================= -->
        <UniformGrid Grid.Row="1" Columns="4" Margin="0,0,0,20">

            <!-- LIBRES -->
            <Border Background="White" CornerRadius="12" Padding="15" Margin="8" BorderBrush="#E5E7EB" BorderThickness="1">
                <StackPanel>

                    <StackPanel Orientation="Horizontal">
                        <fa:ImageAwesome Icon="CheckCircle"
                                         Foreground="#16A34A"
                                         Width="16"
                                         Margin="0,0,8,0"/>
                        <TextBlock Text="Libres" Foreground="#6B7280"/>
                    </StackPanel>

                    <TextBlock x:Name="txtLibres"
                               Text="0"
                               FontSize="26"
                               FontWeight="Bold"
                               Foreground="#16A34A"/>
                </StackPanel>
            </Border>

            <!-- OCCUPES -->
            <Border Background="White" CornerRadius="12" Padding="15" Margin="8" BorderBrush="#E5E7EB" BorderThickness="1">
                <StackPanel>

                    <StackPanel Orientation="Horizontal">
                        <fa:ImageAwesome Icon="TimesCircle"
                                         Foreground="#DC2626"
                                         Width="16"
                                         Margin="0,0,8,0"/>
                        <TextBlock Text="Occupés" Foreground="#6B7280"/>
                    </StackPanel>

                    <TextBlock x:Name="txtOccupes"
                               Text="0"
                               FontSize="26"
                               FontWeight="Bold"
                               Foreground="#DC2626"/>
                </StackPanel>
            </Border>

            <!-- MAINTENANCE -->
            <Border Background="White" CornerRadius="12" Padding="15" Margin="8" BorderBrush="#E5E7EB" BorderThickness="1">
                <StackPanel>

                    <StackPanel Orientation="Horizontal">
                        <fa:ImageAwesome Icon="Wrench"
                                         Foreground="#F59E0B"
                                         Width="16"
                                         Margin="0,0,8,0"/>
                        <TextBlock Text="Maintenance" Foreground="#6B7280"/>
                    </StackPanel>

                    <TextBlock x:Name="txtMaintenance"
                               Text="0"
                               FontSize="26"
                               FontWeight="Bold"
                               Foreground="#F59E0B"/>
                </StackPanel>
            </Border>

            <!-- CLIENTS -->
            <Border Background="White" CornerRadius="12" Padding="15" Margin="8" BorderBrush="#E5E7EB" BorderThickness="1">
                <StackPanel>

                    <StackPanel Orientation="Horizontal">
                        <fa:ImageAwesome Icon="Users"
                                         Foreground="#2563EB"
                                         Width="16"
                                         Margin="0,0,8,0"/>
                        <TextBlock Text="Clients actifs" Foreground="#6B7280"/>
                    </StackPanel>

                    <TextBlock x:Name="txtClientsActifs"
                               Text="0"
                               FontSize="26"
                               FontWeight="Bold"
                               Foreground="#2563EB"/>
                </StackPanel>
            </Border>

        </UniformGrid>

        <!-- ================= TABLE ================= -->
        <Border Grid.Row="2"
                Background="White"
                CornerRadius="14"
                Padding="10"
                BorderBrush="#E5E7EB"
                BorderThickness="1">

            <DataGrid x:Name="dgMonitoring"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      GridLinesVisibility="None"
                      HeadersVisibility="Column"
                      RowHeight="42">

                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#F3F4F6"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="Height" Value="42"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>

                <DataGrid.Columns>

                    <DataGridTextColumn Header="Poste" Binding="{Binding NomPoste}" Width="100"/>
                    <DataGridTextColumn Header="Client" Binding="{Binding NomClient}" Width="120"/>
                    <DataGridTextColumn Header="Téléphone" Binding="{Binding Telephone}" Width="120"/>
                    <DataGridTextColumn Header="Début" Binding="{Binding HeureDebut}" Width="90"/>
                    <DataGridTextColumn Header="Fin" Binding="{Binding HeureFin}" Width="90"/>
                    <DataGridTextColumn Header="Durée" Binding="{Binding DureeMinutes}" Width="80"/>
                    <DataGridTextColumn Header="Montant" Binding="{Binding MontantTotal}" Width="110"/>
                    <DataGridTextColumn Header="Session" Binding="{Binding Statut}" Width="100"/>
                    <DataGridTextColumn Header="Statut Poste" Binding="{Binding StatutPoste}" Width="120"/>

                    <!-- ACTIONS -->
                    <DataGridTemplateColumn Header="Actions" Width="140">

                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>

                                <StackPanel Orientation="Horizontal">

                                    <Button Background="#F59E0B"
                                            Foreground="White"
                                            Margin="2"
                                            Tag="{Binding NomPoste}"
                                            Click="BtnMaintenance_Click">

                                        <StackPanel Orientation="Horizontal">
                                            <fa:ImageAwesome Icon="Wrench" Width="12" Margin="0,0,5,0"/>
                                            
                                        </StackPanel>

                                    </Button>

                                    <Button Background="#16A34A"
                                            Foreground="White"
                                            Margin="2"
                                            Tag="{Binding NomPoste}"
                                            Click="BtnLibre_Click">

                                        <StackPanel Orientation="Horizontal">
                                            <fa:ImageAwesome Icon="CheckCircle" Width="12" Margin="0,0,5,0"/>
                                           
                                        </StackPanel>

                                    </Button>

                                    <Button Background="#DC2626"
                                            Foreground="White"
                                            Margin="2"
                                            Tag="{Binding NomPoste}"
                                            Click="BtnTerminer_Click">

                                        <StackPanel Orientation="Horizontal">
                                            <fa:ImageAwesome Icon="TimesCircle" Width="12" Margin="0,0,5,0"/>
                                            
                                        </StackPanel>

                                    </Button>

                                </StackPanel>

                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>

                    </DataGridTemplateColumn>

                </DataGrid.Columns>

            </DataGrid>

        </Border>

    </Grid>

</UserControl>