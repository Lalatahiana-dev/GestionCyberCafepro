<UserControl x:Class="Gestion_CyberCafe.Views.Parametre.ParametreGeneralView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:fa="http://schemas.fontawesome.io/icons/"
             Background="#F9FAFB">

    <Grid Margin="20">

        <Border Background="White"
                CornerRadius="12"
                BorderBrush="#E5E7EB"
                BorderThickness="1"
                Padding="20">

            <StackPanel>

                <!-- ================= TITLE ================= -->
                <DockPanel Margin="0,0,0,20">

                    <fa:ImageAwesome Icon="Building"
                                     Width="22"
                                     Height="22"
                                     Foreground="#2563EB"
                                     Margin="0,0,10,0"/>

                    <TextBlock Text="Paramètres généraux"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="#111827"/>
                </DockPanel>

                <!-- ================= NOM ================= -->
                <StackPanel Margin="0,0,0,12">

                    <DockPanel Margin="0,0,0,5">
                        <fa:ImageAwesome Icon="Tag"
                                         Width="14"
                                         Height="14"
                                         Foreground="#6B7280"
                                         Margin="0,0,6,0"/>
                        <TextBlock Text="Nom du Cyber"
                                   Foreground="#6B7280"/>
                    </DockPanel>

                    <TextBox x:Name="txtNomCyber"
                             Height="38"/>

                </StackPanel>

                <!-- ================= ADRESSE ================= -->
                <StackPanel Margin="0,0,0,12">

                    <DockPanel Margin="0,0,0,5">
                        <fa:ImageAwesome Icon="MapMarker"
                                         Width="14"
                                         Height="14"
                                         Foreground="#6B7280"
                                         Margin="0,0,6,0"/>
                        <TextBlock Text="Adresse"
                                   Foreground="#6B7280"/>
                    </DockPanel>

                    <TextBox x:Name="txtAdresse"
                             Height="38"/>

                </StackPanel>

                <!-- ================= TELEPHONE ================= -->
                <StackPanel Margin="0,0,0,20">

                    <DockPanel Margin="0,0,0,5">
                        <fa:ImageAwesome Icon="Phone"
                                         Width="14"
                                         Height="14"
                                         Foreground="#6B7280"
                                         Margin="0,0,6,0"/>
                        <TextBlock Text="Téléphone"
                                   Foreground="#6B7280"/>
                    </DockPanel>

                    <TextBox x:Name="txtTelephone"
                             Height="38"/>

                </StackPanel>

                <!-- ================= BUTTON ================= -->
                <Button Height="42"
                        Background="#2563EB"
                        Foreground="White"
                        FontWeight="SemiBold"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="BtnSave_Click">

                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    CornerRadius="10"
                                    Padding="10">

                                <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Center">

                                    <fa:ImageAwesome Icon="Save"
                                                     Width="14"
                                                     Height="14"
                                                     Margin="0,0,8,0"
                                                     Foreground="White"/>

                                    <ContentPresenter/>
                                </StackPanel>

                            </Border>
                        </ControlTemplate>
                    </Button.Template>

                </Button>

            </StackPanel>

        </Border>

    </Grid>

</UserControl>