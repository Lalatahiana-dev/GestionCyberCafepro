<UserControl x:Class="Gestion_CyberCafe.Views.Parametre.ParametrePosteView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:fa="http://schemas.fontawesome.io/icons/"
             Background="#F9FAFB">

    <UserControl.Resources>

        <!-- BUTTON STYLE -->
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="Margin" Value="6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10"
                                Padding="10">

                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.85"/>
                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>

                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <!-- MAIN LAYOUT -->
    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ================= TOP CARD ================= -->
        <Border Grid.Row="0"
                Background="White"
                CornerRadius="15"
                BorderBrush="#E5E7EB"
                BorderThickness="1"
                Padding="20"
                Margin="0,0,0,15">

            <StackPanel>

                <!-- TITLE -->
                <DockPanel Margin="0,0,0,15">

                    <fa:ImageAwesome Icon="Desktop"
                                     Width="20"
                                     Height="20"
                                     Foreground="#2563EB"
                                     Margin="0,0,10,0"/>

                    <TextBlock Text="Gestion des postes"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="#111827"/>
                </DockPanel>

                <!-- SEARCH -->
                <TextBlock Text="Recherche"
                           Foreground="#6B7280"/>

                <TextBox x:Name="txtSearch"
                         Height="38"
                         Margin="0,5,0,15"
                         BorderBrush="#E5E7EB"/>

                <!-- FORM -->
                <Grid Margin="0,0,0,10">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- NOM -->
                    <StackPanel Grid.Column="0" Margin="5">
                        <TextBlock Text="Nom poste" Foreground="#6B7280"/>
                        <TextBox x:Name="txtNomPoste" Height="38"/>
                    </StackPanel>

                    <!-- DESCRIPTION -->
                    <StackPanel Grid.Column="1" Margin="5">
                        <TextBlock Text="Description" Foreground="#6B7280"/>
                        <TextBox x:Name="txtDescription" Height="38"/>
                    </StackPanel>

                    <!-- STATUT -->
                    <StackPanel Grid.Column="2" Margin="5">
                        <TextBlock Text="Statut" Foreground="#6B7280"/>
                        <ComboBox x:Name="cbStatut" Height="38">
                            <ComboBoxItem Content="LIBRE"/>
                            <ComboBoxItem Content="OCCUPE"/>
                            <ComboBoxItem Content="MAINTENANCE"/>
                        </ComboBox>
                    </StackPanel>

                </Grid>

                <!-- BUTTONS -->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Margin="0,10,0,0">

                    <!-- AJOUT -->
                    <Button Style="{StaticResource ActionButtonStyle}"
                            Background="#2563EB"
                            Click="BtnAjouter_Click">
                        <StackPanel Orientation="Horizontal">
                            <fa:ImageAwesome Icon="Plus" Width="14" Height="14" Margin="0,0,8,0"/>
                            <TextBlock Text="Ajouter"/>
                        </StackPanel>
                    </Button>

                    <!-- MODIF -->
                    <Button Style="{StaticResource ActionButtonStyle}"
                            Background="#6B7280"
                            Click="BtnModifier_Click">
                        <StackPanel Orientation="Horizontal">
                            <fa:ImageAwesome Icon="Edit" Width="14" Height="14" Margin="0,0,8,0"/>
                            <TextBlock Text="Modifier"/>
                        </StackPanel>
                    </Button>

                    <!-- DELETE -->
                    <Button Style="{StaticResource ActionButtonStyle}"
                            Background="#DC2626"
                            Click="BtnSupprimer_Click">
                        <StackPanel Orientation="Horizontal">
                            <fa:ImageAwesome Icon="Trash" Width="14" Height="14" Margin="0,0,8,0"/>
                            <TextBlock Text="Supprimer"/>
                        </StackPanel>
                    </Button>

                    <!-- CLEAR -->
                    <Button Style="{StaticResource ActionButtonStyle}"
                            Background="#9CA3AF"
                            Click="BtnClear_Click">
                        <StackPanel Orientation="Horizontal">
                            <fa:ImageAwesome Icon="Refresh" Width="14" Height="14" Margin="0,0,8,0"/>
                            <TextBlock Text="Vider"/>
                        </StackPanel>
                    </Button>

                </StackPanel>

            </StackPanel>

        </Border>

        <!-- ================= TABLE ================= -->
        <Border Grid.Row="1"
                Background="White"
                CornerRadius="15"
                BorderBrush="#E5E7EB"
                BorderThickness="1"
                Padding="10">

            <DataGrid x:Name="dgPostes"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      GridLinesVisibility="None"
                      RowHeight="42"
                      HeadersVisibility="Column"
                      SelectionChanged="DgPostes_SelectionChanged"
                      AlternatingRowBackground="#F9FAFB">

                <DataGrid.Columns>

                    <DataGridTextColumn Header="ID"
                                        Binding="{Binding IdPoste}"
                                        Width="80"/>

                    <DataGridTextColumn Header="Nom Poste"
                                        Binding="{Binding NomPoste}"
                                        Width="*"/>

                    <DataGridTextColumn Header="Description"
                                        Binding="{Binding Description}"
                                        Width="*"/>

                    <DataGridTextColumn Header="Statut"
                                        Binding="{Binding Statut}"
                                        Width="140"/>

                </DataGrid.Columns>

            </DataGrid>

        </Border>

    </Grid>

</UserControl>