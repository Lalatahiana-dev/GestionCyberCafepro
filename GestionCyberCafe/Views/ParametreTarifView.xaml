<UserControl x:Class="Gestion_CyberCafe.Views.Parametre.ParametreTarifView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="White">

    <ScrollViewer VerticalScrollBarVisibility="Auto">

        <Grid Margin="20">

            <StackPanel>

                <!-- TITLE -->
                <TextBlock Text="💰 PARAMÈTRES TARIFS"
                           FontSize="24"
                           FontWeight="Bold"
                           Foreground="#1E293B"
                           Margin="0,0,0,20"/>

                <!-- ================= POSTE ================= -->
                <Border Background="#F9FAFB"
                        Padding="15"
                        CornerRadius="10"
                        BorderBrush="#E5E7EB"
                        BorderThickness="1"
                        Margin="0,0,0,15">

                    <StackPanel>

                        <TextBlock Text="🖥 POSTE"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Margin="0,0,0,10"/>

                        <TextBlock Text="Prix Heure PC"/>
                        <TextBox x:Name="txtPrixHeurePC"
                                 Height="35"
                                 Margin="0,5,0,10"/>

                        <TextBlock Text="Prix Minute PC"/>
                        <TextBox x:Name="txtPrixMinutePC"
                                 Height="35"/>

                    </StackPanel>

                </Border>

                <!-- ================= WIFI ================= -->
                <Border Background="#F9FAFB"
                        Padding="15"
                        CornerRadius="10"
                        BorderBrush="#E5E7EB"
                        BorderThickness="1"
                        Margin="0,0,0,15">

                    <StackPanel>

                        <TextBlock Text="📶 WIFI"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Margin="0,0,0,10"/>

                        <TextBlock Text="Prix Heure Wifi"/>
                        <TextBox x:Name="txtPrixHeureWifi"
                                 Height="35"
                                 Margin="0,5,0,10"/>

                        <TextBlock Text="Prix Minute Wifi"/>
                        <TextBox x:Name="txtPrixMinuteWifi"
                                 Height="35"/>

                    </StackPanel>

                </Border>

                <!-- ================= FORFAITS ================= -->
                <Border Background="#F9FAFB"
                        Padding="15"
                        CornerRadius="10"
                        BorderBrush="#E5E7EB"
                        BorderThickness="1">

                    <StackPanel>

                        <TextBlock Text="📦 FORFAITS POSTE"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Margin="0,0,0,10"/>

                        <TextBlock Text="Semaine"/>
                        <TextBox x:Name="txtSemaine"
                                 Height="35"
                                 Margin="0,5,0,10"/>

                        <TextBlock Text="Mois"/>
                        <TextBox x:Name="txtMois"
                                 Height="35"
                                 Margin="0,5,0,10"/>

                        <TextBlock Text="Année"/>
                        <TextBox x:Name="txtAnnee"
                                 Height="35"
                                 Margin="0,5,0,15"/>

                    </StackPanel>

                </Border>

                <!-- BUTTON -->
                <Button Content="💾 ENREGISTRER"
                        Height="45"
                        Margin="0,20,0,0"
                        Background="#2563EB"
                        Foreground="White"
                        FontWeight="Bold"
                        Click="BtnSave_Click"/>

            </StackPanel>

        </Grid>

    </ScrollViewer>

</UserControl>