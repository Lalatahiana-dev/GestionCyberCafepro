<UserControl x:Class="Gestion_CyberCafe.Views.Parametre.ParametreTarifView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:fa="http://schemas.fontawesome.io/icons/"
             Background="#F9FAFB">

    <ScrollViewer VerticalScrollBarVisibility="Auto">

        <Grid Margin="20">

            <StackPanel Margin="0,0,65,0">

                <!-- ================= TITLE ================= -->
                <DockPanel Margin="0,0,0,20">

                    <fa:ImageAwesome Icon="Money"
                                     Width="22"
                                     Height="22"
                                     Foreground="#2563EB"
                                     Margin="0,0,10,0"/>

                    <TextBlock Text="Paramètres Tarifs"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="#111827"/>
                </DockPanel>

                <!-- ================= POSTE ================= -->
                <Border Background="White"
                        Padding="15"
                        CornerRadius="12"
                        BorderBrush="#E5E7EB"
                        BorderThickness="1"
                        Margin="0,0,0,15">

                    <StackPanel>

                        <DockPanel Margin="0,0,0,10">

                            <fa:ImageAwesome Icon="Desktop"
                                             Width="18"
                                             Height="18"
                                             Foreground="#2563EB"
                                             Margin="0,0,8,0"/>

                            <TextBlock Text="POSTE"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="#111827"/>
                        </DockPanel>

                        <TextBlock Text="Prix Heure PC" Foreground="#6B7280"/>
                        <TextBox x:Name="txtPrixHeurePC"
                                 Height="38"
                                 Margin="0,5,0,10"/>

                        <TextBlock Text="Prix Minute PC" Foreground="#6B7280"/>
                        <TextBox x:Name="txtPrixMinutePC"
                                 Height="38"/>

                    </StackPanel>

                </Border>

                <!-- ================= WIFI ================= -->
                <Border Background="White"
                        Padding="15"
                        CornerRadius="12"
                        BorderBrush="#E5E7EB"
                        BorderThickness="1"
                        Margin="0,0,0,15">

                    <StackPanel>

                        <DockPanel Margin="0,0,0,10">

                            <fa:ImageAwesome Icon="Wifi"
                                             Width="18"
                                             Height="18"
                                             Foreground="#2563EB"
                                             Margin="0,0,8,0"/>

                            <TextBlock Text="WIFI"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="#111827"/>
                        </DockPanel>

                        <TextBlock Text="Prix Heure Wifi" Foreground="#6B7280"/>
                        <TextBox x:Name="txtPrixHeureWifi"
                                 Height="38"
                                 Margin="0,5,0,10"/>

                        <TextBlock Text="Prix Minute Wifi" Foreground="#6B7280"/>
                        <TextBox x:Name="txtPrixMinuteWifi"
                                 Height="38"/>

                    </StackPanel>

                </Border>

                <!-- ================= FORFAITS ================= -->
                <Border Background="White"
                        Padding="15"
                        CornerRadius="12"
                        BorderBrush="#E5E7EB"
                        BorderThickness="1">

                    <StackPanel>

                        <DockPanel Margin="0,0,0,10">

                            <fa:ImageAwesome Icon="Archive"
                                             Width="18"
                                             Height="18"
                                             Foreground="#2563EB"
                                             Margin="0,0,8,0"/>

                            <TextBlock Text="FORFAITS POSTE"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="#111827"/>
                        </DockPanel>

                        <TextBlock Text="Semaine" Foreground="#6B7280"/>
                        <TextBox x:Name="txtSemaine"
                                 Height="38"
                                 Margin="0,5,0,10"/>

                        <TextBlock Text="Mois" Foreground="#6B7280"/>
                        <TextBox x:Name="txtMois"
                                 Height="38"
                                 Margin="0,5,0,10"/>

                        <TextBlock Text="Année" Foreground="#6B7280"/>
                        <TextBox x:Name="txtAnnee"
                                 Height="38"/>

                    </StackPanel>

                </Border>

                <!-- ================= BUTTON ================= -->
                <Button Content=""
                        Height="45"
                        Margin="0,20,0,0"
                        Background="#2563EB"
                        Foreground="White"
                        FontWeight="Bold"
                        BorderThickness="0"
                        Cursor="Hand"
                        Click="BtnSave_Click">

                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    CornerRadius="10"
                                    Padding="10">
                                <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Center">

                                    <fa:ImageAwesome Icon="Save"
                                                     Width="14"
                                                     Height="14"
                                                     Margin="0,0,8,0"
                                                     Foreground="White"/>

                                    <ContentPresenter/>
                                </StackPanel>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>

                </Button>

            </StackPanel>

        </Grid>

    </ScrollViewer>

</UserControl>