<UserControl x:Class="Gestion_CyberCafe.Views.Parametre.ParametreUserView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:fa="http://schemas.fontawesome.io/icons/"
             Background="#F9FAFB">

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ================= TOP CARD ================= -->
        <Border Grid.Row="0"
                Background="White"
                CornerRadius="12"
                BorderBrush="#E5E7EB"
                BorderThickness="1"
                Padding="15"
                Margin="0,0,0,15">

            <StackPanel>

                <!-- TITLE -->
                <DockPanel Margin="0,0,0,15">

                    <fa:ImageAwesome Icon="Users"
                                     Width="20"
                                     Height="20"
                                     Foreground="#2563EB"
                                     Margin="0,0,10,0"/>

                    <TextBlock Text="Gestion des utilisateurs"
                               FontSize="22"
                               FontWeight="SemiBold"
                               Foreground="#111827"/>
                </DockPanel>

                <!-- SEARCH -->
                <Border Background="#F9FAFB"
                        CornerRadius="8"
                        BorderBrush="#E5E7EB"
                        BorderThickness="1"
                        Padding="5"
                        Margin="0,0,0,15">

                    <Grid Height="38">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="40"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <fa:ImageAwesome Icon="Search"
                                         Width="14"
                                         Height="14"
                                         Foreground="#6B7280"
                                         HorizontalAlignment="Center"
                                         VerticalAlignment="Center"/>

                        <TextBox x:Name="txtSearch"
                                 Grid.Column="1"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 VerticalContentAlignment="Center"/>

                    </Grid>

                </Border>

                <!-- FORM -->
                <Grid Margin="0,0,0,15">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- USERNAME -->
                    <StackPanel Grid.Column="0" Margin="5">
                        <TextBlock Text="Nom utilisateur" Foreground="#6B7280"/>
                        <TextBox x:Name="txtUsername" Height="38"/>
                    </StackPanel>

                    <!-- PASSWORD -->
                    <StackPanel Grid.Column="1" Margin="5">
                        <TextBlock Text="Mot de passe" Foreground="#6B7280"/>
                        <PasswordBox x:Name="txtPassword" Height="38"/>
                    </StackPanel>

                    <!-- ROLE -->
                    <StackPanel Grid.Column="2" Margin="5">
                        <TextBlock Text="Rôle" Foreground="#6B7280"/>
                        <ComboBox x:Name="cbRole" Height="38">
                            <ComboBoxItem Content="ADMIN"/>
                            <ComboBoxItem Content="CAISSIER"/>
                        </ComboBox>
                    </StackPanel>

                </Grid>

                <!-- BUTTONS -->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right">

                    <!-- AJOUT -->
                    <Button Width="110"
                            Height="38"
                            Margin="5"
                            Background="#2563EB"
                            Foreground="White"
                            BorderThickness="0"
                            Click="BtnAjouter_Click">

                        <StackPanel Orientation="Horizontal">
                            <fa:ImageAwesome Icon="Plus" Width="12" Height="12" Margin="0,0,8,0"/>
                            <TextBlock Text="Ajouter"/>
                        </StackPanel>

                    </Button>

                    <!-- MODIFIER -->
                    <Button Width="110"
                            Height="38"
                            Margin="5"
                            Background="#6B7280"
                            Foreground="White"
                            BorderThickness="0"
                            Click="BtnModifier_Click">

                        <StackPanel Orientation="Horizontal">
                            <fa:ImageAwesome Icon="Edit" Width="12" Height="12" Margin="0,0,8,0"/>
                            <TextBlock Text="Modifier"/>
                        </StackPanel>

                    </Button>

                    <!-- SUPPRIMER -->
                    <Button Width="110"
                            Height="38"
                            Margin="5"
                            Background="#DC2626"
                            Foreground="White"
                            BorderThickness="0"
                            Click="BtnSupprimer_Click">

                        <StackPanel Orientation="Horizontal">
                            <fa:ImageAwesome Icon="Trash" Width="12" Height="12" Margin="0,0,8,0"/>
                            <TextBlock Text="Supprimer"/>
                        </StackPanel>

                    </Button>

                    <!-- VIDER -->
                    <Button Width="110"
                            Height="38"
                            Margin="5"
                            Background="#9CA3AF"
                            Foreground="White"
                            BorderThickness="0"
                            Click="BtnClear_Click">

                        <StackPanel Orientation="Horizontal">
                            <fa:ImageAwesome Icon="Refresh" Width="12" Height="12" Margin="0,0,8,0"/>
                            <TextBlock Text="Vider"/>
                        </StackPanel>

                    </Button>

                </StackPanel>

            </StackPanel>

        </Border>

        <!-- ================= TABLE ================= -->
        <Border Grid.Row="1"
                Background="White"
                CornerRadius="12"
                BorderBrush="#E5E7EB"
                BorderThickness="1"
                Padding="10">

            <DataGrid x:Name="dgUsers"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      SelectionChanged="DgUsers_SelectionChanged"
                      GridLinesVisibility="None"
                      RowHeight="40"
                      HeadersVisibility="Column"
                      Background="White"
                      AlternatingRowBackground="#F9FAFB">

                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#F3F4F6"/>
                        <Setter Property="Foreground" Value="#111827"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="Height" Value="40"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>

                <DataGrid.Columns>

                    <DataGridTextColumn Header="ID"
                                        Binding="{Binding IdUser}"
                                        Width="80"/>

                    <DataGridTextColumn Header="Nom utilisateur"
                                        Binding="{Binding Username}"
                                        Width="*"/>

                    <DataGridTextColumn Header="Rôle"
                                        Binding="{Binding Role}"
                                        Width="150"/>

                </DataGrid.Columns>

            </DataGrid>

        </Border>

    </Grid>

</UserControl>