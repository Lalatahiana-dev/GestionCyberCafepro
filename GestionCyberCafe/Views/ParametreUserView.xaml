<UserControl x:Class="Gestion_CyberCafe.Views.Parametre.ParametreUserView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F9FAFB" >

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ================= TOP FORM + SEARCH ================= -->
        <Border Grid.Row="0"
                Background="White"
                BorderBrush="#E5E7EB"
                BorderThickness="1"
                CornerRadius="12"
                Padding="15"
                Margin="0,0,0,15">

            <StackPanel>

                <!-- TITLE -->
                <TextBlock Text="Gestion des utilisateurs"
                           FontSize="22"
                           FontWeight="SemiBold"
                           Foreground="#111827"
                           Margin="0,0,0,15"/>

                <!-- SEARCH -->
                <TextBlock Text="Recherche utilisateur"
                           Foreground="#6B7280"/>
                <TextBox x:Name="txtSearch"
                         Height="35"
                         Margin="0,5,0,15"
                         BorderBrush="#E5E7EB"/>

                <!-- FORM -->
                <Grid Margin="0,0,0,15">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- USERNAME -->
                    <StackPanel Grid.Column="0" Margin="5">
                        <TextBlock Text="Nom utilisateur"
                                   Foreground="#6B7280"/>
                        <TextBox x:Name="txtUsername"
                                 Height="35"
                                 Margin="0,5,0,0"
                                 BorderBrush="#E5E7EB"/>
                    </StackPanel>

                    <!-- PASSWORD -->
                    <StackPanel Grid.Column="1" Margin="5">
                        <TextBlock Text="Mot de passe"
                                   Foreground="#6B7280"/>
                        <PasswordBox x:Name="txtPassword"
                                     Height="35"
                                     Margin="0,5,0,0"/>
                    </StackPanel>

                    <!-- ROLE -->
                    <StackPanel Grid.Column="2" Margin="5">
                        <TextBlock Text="Rôle"
                                   Foreground="#6B7280"/>
                        <ComboBox x:Name="cbRole"
                                  Height="35"
                                  Margin="0,5,0,0">
                            <ComboBoxItem Content="ADMIN"/>
                            <ComboBoxItem Content="CAISSIER"/>
                        </ComboBox>
                    </StackPanel>

                </Grid>

                <!-- BUTTONS -->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right">

                    <Button Content="Ajouter"
                            Width="110"
                            Height="36"
                            Margin="5"
                            Background="#2563EB"
                            Foreground="White"
                            BorderThickness="0"
                            Click="BtnAjouter_Click"/>

                    <Button Content="Modifier"
                            Width="110"
                            Height="36"
                            Margin="5"
                            Background="#6B7280"
                            Foreground="White"
                            BorderThickness="0"
                            Click="BtnModifier_Click"/>

                    <Button Content="Supprimer"
                            Width="110"
                            Height="36"
                            Margin="5"
                            Background="#DC2626"
                            Foreground="White"
                            BorderThickness="0"
                            Click="BtnSupprimer_Click"/>

                    <Button Content="Vider"
                            Width="110"
                            Height="36"
                            Margin="5"
                            Background="#9CA3AF"
                            Foreground="White"
                            BorderThickness="0"
                            Click="BtnClear_Click"/>

                </StackPanel>

            </StackPanel>

        </Border>

        <!-- ================= DATAGRID ================= -->
        <Border Grid.Row="1"
                Background="White"
                BorderBrush="#E5E7EB"
                BorderThickness="1"
                CornerRadius="12"
                Padding="10">

            <DataGrid x:Name="dgUsers"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      SelectionChanged="DgUsers_SelectionChanged"
                      GridLinesVisibility="None"
                      RowHeight="40"
                      HeadersVisibility="Column"
                      Background="White">

                <!-- HEADER STYLE -->
                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#F3F4F6"/>
                        <Setter Property="Foreground" Value="#111827"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="Height" Value="40"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>

                <DataGrid.Columns>

                    <DataGridTextColumn Header="ID"
                                        Binding="{Binding IdUser}"
                                        Width="80"/>

                    <DataGridTextColumn Header="Nom Utilisateur"
                                        Binding="{Binding Username}"
                                        Width="*"/>

                    <DataGridTextColumn Header="Rôle"
                                        Binding="{Binding Role}"
                                        Width="150"/>

                </DataGrid.Columns>

            </DataGrid>

        </Border>

    </Grid>

</UserControl>