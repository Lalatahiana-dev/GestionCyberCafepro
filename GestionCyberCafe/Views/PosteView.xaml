<UserControl x:Class="Gestion_CyberCafe.Views.PosteView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:fa="http://schemas.fontawesome.io/icons/"
             Background="#F4F6F9">

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ================= HEADER ================= -->
        <Border Background="White"
                CornerRadius="12"
                Padding="18"
                BorderBrush="#E5E7EB"
                BorderThickness="1">

            <DockPanel>

                <StackPanel Orientation="Horizontal">

                    <fa:ImageAwesome Icon="Desktop"
                                     Width="22"
                                     Height="22"
                                     Foreground="#111827"
                                     Margin="0,0,10,0"/>

                    <TextBlock Text="Gestion des Postes"
                               FontSize="22"
                               FontWeight="SemiBold"
                               Foreground="#111827"/>

                </StackPanel>

            </DockPanel>

        </Border>

        <!-- ================= NAV BUTTONS ================= -->
        <Border Grid.Row="1"
                Margin="0,15,0,15"
                Background="White"
                CornerRadius="12"
                Padding="12"
                BorderBrush="#E5E7EB"
                BorderThickness="1">

            <UniformGrid Columns="4">

                <Button Margin="6"
                        Height="44"
                        Background="#2563EB"
                        Foreground="White"
                        BorderThickness="0"
                        FontWeight="SemiBold"
                        Cursor="Hand"
                        Click="BtnSession_Click">

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">

                        <fa:ImageAwesome Icon="PlusCircle"
                                         Width="14"
                                         Height="14"
                                         Margin="0,0,8,0"
                                         Foreground="White"/>

                        <TextBlock Text="Session PC"/>

                    </StackPanel>

                </Button>

                <Button Margin="6"
                        Height="44"
                        Background="#16A34A"
                        Foreground="White"
                        BorderThickness="0"
                        FontWeight="SemiBold"
                        Cursor="Hand"
                        Click="BtnMonitoring_Click">

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">

                        <fa:ImageAwesome Icon="LineChart"
                                         Width="14"
                                         Height="14"
                                         Margin="0,0,8,0"
                                         Foreground="White"/>

                        <TextBlock Text="Monitoring"/>

                    </StackPanel>

                </Button>

                <Button Margin="6"
                        Height="44"
                        Background="#6B7280"
                        Foreground="White"
                        BorderThickness="0"
                        FontWeight="SemiBold"
                        Cursor="Hand"
                        Click="BtnHistorique_Click">

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">

                        <fa:ImageAwesome Icon="History"
                                         Width="14"
                                         Height="14"
                                         Margin="0,0,8,0"
                                         Foreground="White"/>

                        <TextBlock Text="Historique"/>

                    </StackPanel>

                </Button>

                <Button Margin="6"
                        Height="44"
                        Background="#111827"
                        Foreground="White"
                        BorderThickness="0"
                        FontWeight="SemiBold"
                        Cursor="Hand"
                        Click="BtnGestion_Click">

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">

                        <fa:ImageAwesome Icon="Cog"
                                         Width="14"
                                         Height="14"
                                         Margin="0,0,8,0"
                                         Foreground="White"/>

                        <TextBlock Text="Gestion"/>

                    </StackPanel>

                </Button>

            </UniformGrid>

        </Border>

        <!-- ================= CONTENT AREA ================= -->
        <Border Grid.Row="2"
                Background="White"
                CornerRadius="12"
                Padding="15"
                BorderBrush="#E5E7EB"
                BorderThickness="1">

            <ContentControl x:Name="MainArea"/>

        </Border>

    </Grid>

</UserControl>