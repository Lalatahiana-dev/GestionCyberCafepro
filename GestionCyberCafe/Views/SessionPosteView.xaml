<UserControl x:Class="Gestion_CyberCafe.Views.Poste.SessionPosteView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:fa="http://schemas.fontawesome.io/icons/"
             Background="#F4F6F9">

    <ScrollViewer>

        <Grid Margin="20">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ================= TITLE ================= -->
            <DockPanel Margin="0,0,0,20">

                <fa:ImageAwesome Icon="PlusCircle"
                                 Width="24"
                                 Height="24"
                                 Foreground="#2563EB"
                                 Margin="0,0,10,0"/>

                <TextBlock Text="Nouvelle Session Poste"
                           FontSize="22"
                           FontWeight="SemiBold"
                           Foreground="#111827"/>

            </DockPanel>

            <Grid Grid.Row="1">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.2*"/>
                    <ColumnDefinition Width="1.8*"/>
                </Grid.ColumnDefinitions>

                <!-- ================= CLIENT ================= -->
                <Border Grid.Column="0"
                        Background="White"
                        CornerRadius="12"
                        Padding="18"
                        Margin="5"
                        BorderBrush="#E5E7EB"
                        BorderThickness="1">

                    <StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,15">

                            <fa:ImageAwesome Icon="User"
                                             Width="16"
                                             Height="16"
                                             Foreground="#2563EB"
                                             Margin="0,0,8,0"/>

                            <TextBlock Text="CLIENT"
                                       FontWeight="SemiBold"
                                       Foreground="#111827"/>
                        </StackPanel>

                        <TextBlock Text="Nom"/>
                        <TextBox x:Name="txtNom" Height="35" Margin="0,5,0,10"/>

                        <TextBlock Text="Prénom"/>
                        <TextBox x:Name="txtPrenom" Height="35" Margin="0,5,0,10"/>

                        <TextBlock Text="Téléphone"/>
                        <TextBox x:Name="txtTelephone" Height="35" Margin="0,5,0,10"/>

                        <TextBlock Text="Adresse"/>
                        <TextBox x:Name="txtAdresse" Height="35"/>

                    </StackPanel>

                </Border>

                <!-- ================= SESSION ================= -->
                <Border Grid.Column="1"
                        Background="White"
                        CornerRadius="12"
                        Padding="18"
                        Margin="10,0,0,0"
                        BorderBrush="#E5E7EB"
                        BorderThickness="1">

                    <StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,15">

                            <fa:ImageAwesome Icon="Desktop"
                                             Width="16"
                                             Height="16"
                                             Foreground="#16A34A"
                                             Margin="0,0,8,0"/>

                            <TextBlock Text="SESSION POSTE"
                                       FontWeight="SemiBold"
                                       Foreground="#111827"/>
                        </StackPanel>

                        <!-- POSTE -->
                        <TextBlock Text="Poste disponible"/>
                        <ComboBox x:Name="cbPostes"
                                  Height="35"
                                  Margin="0,5,0,10"
                                  DisplayMemberPath="NomPoste"
                                  SelectedValuePath="IdPoste"/>

                        <!-- DATE -->
                        <TextBlock Text="Date"/>
                        <DatePicker x:Name="dpDate" Margin="0,5,0,10"/>

                        <!-- HEURE -->
                        <TextBlock Text="Heure début"/>
                        <TextBox x:Name="txtHeureDebut" Height="35" Margin="0,5,0,10"/>

                        <!-- DURÉE -->
                        <Grid Margin="0,5,0,10">

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Heure"/>
                                <TextBox x:Name="txtHeure" Height="35"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                <TextBlock Text="Minute"/>
                                <TextBox x:Name="txtMinute" Height="35"/>
                            </StackPanel>

                        </Grid>

                        <!-- RESUME -->
                        <Border Background="#F9FAFB"
                                CornerRadius="10"
                                Padding="12"
                                Margin="0,10">

                            <Grid>

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/>
                                    <ColumnDefinition/>
                                </Grid.ColumnDefinitions>

                                <StackPanel>

                                    <StackPanel Orientation="Horizontal">

                                        <fa:ImageAwesome Icon="Money"
                                                         Width="14"
                                                         Height="14"
                                                         Foreground="#16A34A"
                                                         Margin="0,0,6,0"/>

                                        <TextBlock Text="Total"/>
                                    </StackPanel>

                                    <TextBlock x:Name="txtMontant"
                                               FontSize="18"
                                               FontWeight="Bold"
                                               Foreground="#16A34A"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1" HorizontalAlignment="Right">

                                    <StackPanel Orientation="Horizontal">

                                        <fa:ImageAwesome Icon="ClockOutline"
                                                         Width="14"
                                                         Height="14"
                                                         Foreground="#E53935"
                                                         Margin="0,0,6,0"/>

                                        <TextBlock Text="Fin"/>
                                    </StackPanel>

                                    <TextBlock x:Name="txtHeureFin"
                                               FontSize="18"
                                               FontWeight="Bold"
                                               Foreground="#E53935"/>
                                </StackPanel>

                            </Grid>

                        </Border>

                        <!-- BUTTON -->
                        <Button Height="42"
                                Background="#2563EB"
                                Foreground="White"
                                FontWeight="SemiBold"
                                BorderThickness="0"
                                Cursor="Hand"
                                Click="StartSession_Click">

                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">

                                <fa:ImageAwesome Icon="Play"
                                                 Width="14"
                                                 Height="14"
                                                 Margin="0,0,8,0"
                                                 Foreground="White"/>

                                <TextBlock Text="LANCER SESSION"/>
                            </StackPanel>

                        </Button>

                    </StackPanel>

                </Border>

            </Grid>

        </Grid>

    </ScrollViewer>

</UserControl>