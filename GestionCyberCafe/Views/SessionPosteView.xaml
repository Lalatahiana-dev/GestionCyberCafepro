<UserControl x:Class="Gestion_CyberCafe.Views.Poste.SessionPosteView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="White">

    <ScrollViewer>

        <Grid Margin="15">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- TITLE -->
            <TextBlock Text="➕ NOUVELLE SESSION POSTE"
                       FontSize="22"
                       FontWeight="Bold"
                       Margin="0,0,0,15"/>

            <Grid Grid.Row="1">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.2*"/>
                    <ColumnDefinition Width="1.8*"/>
                </Grid.ColumnDefinitions>

                <!-- ================= GAUCHE CLIENT ================= -->
                <Border Grid.Column="0"
                        Background="#F5F7FA"
                        CornerRadius="10"
                        Padding="15"
                        Margin="5">

                    <StackPanel>

                        <TextBlock Text="👤 CLIENT"
                                   FontWeight="Bold"
                                   Margin="0,0,0,10"/>

                        <TextBlock Text="Nom"/>
                        <TextBox x:Name="txtNom" Height="35"/>

                        <TextBlock Text="Prénom"/>
                        <TextBox x:Name="txtPrenom" Height="35"/>

                        <TextBlock Text="Téléphone"/>
                        <TextBox x:Name="txtTelephone" Height="35"/>

                        <TextBlock Text="Adresse"/>
                        <TextBox x:Name="txtAdresse" Height="35"/>

                    </StackPanel>

                </Border>

                <!-- ================= DROITE SESSION ================= -->
                <Border Grid.Column="1"
                        Background="White"
                        BorderBrush="#E5E7EB"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="15"
                        Margin="10,0,0,0">

                    <StackPanel>

                        <TextBlock Text="🖥 SESSION POSTE"
                                   FontWeight="Bold"
                                   Margin="0,0,0,10"/>

                        <!-- POSTE SELECT -->
                        <TextBlock Text="Poste disponible"/>
                        <ComboBox x:Name="cbPostes"
                                  Height="35"
                                  Margin="0,5"
                                  DisplayMemberPath="NomPoste"
                                  SelectedValuePath="IdPoste"/>

                        <!-- DATE -->
                        <TextBlock Text="Date"/>
                        <DatePicker x:Name="dpDate"/>

                        <!-- HEURE -->
                        <TextBlock Text="Heure début"/>
                        <TextBox x:Name="txtHeureDebut" Height="35"/>

                        <!-- DUREE -->
                        <Grid Margin="0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Heure"/>
                                <TextBox x:Name="txtHeure"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="5,0,0,0">
                                <TextBlock Text="Minute"/>
                                <TextBox x:Name="txtMinute"/>
                            </StackPanel>

                        </Grid>

                        <!-- RESUME -->
                        <Border Background="#F5F7FA"
                                Padding="10"
                                Margin="0,10">

                            <Grid>

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/>
                                    <ColumnDefinition/>
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <TextBlock Text="Total"/>
                                    <TextBlock x:Name="txtMontant"
                                               FontSize="18"
                                               FontWeight="Bold"
                                               Foreground="#4CAF50"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                    <TextBlock Text="Heure fin"/>
                                    <TextBlock x:Name="txtHeureFin"
                                               FontSize="18"
                                               FontWeight="Bold"
                                               Foreground="#E53935"/>
                                </StackPanel>

                            </Grid>

                        </Border>

                        <!-- BUTTON -->
                        <Button Content="▶ LANCER SESSION"
                                Height="40"
                                Background="#4CAF50"
                                Foreground="White"
                                Click="StartSession_Click"/>

                    </StackPanel>

                </Border>

            </Grid>

        </Grid>

    </ScrollViewer>

</UserControl>