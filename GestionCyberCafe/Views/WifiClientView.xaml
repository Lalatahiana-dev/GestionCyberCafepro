<UserControl x:Class="Gestion_CyberCafe.Views.Wifi.Pages.WifiClientView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F9FAFB">

    <ScrollViewer VerticalScrollBarVisibility="Auto">

        <Grid Margin="20">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <!-- ================= CLIENT ================= -->
            <Border Grid.Column="0"
                    Background="White"
                    CornerRadius="10"
                    Padding="20"
                    Margin="10"
                    BorderBrush="#E5E7EB"
                    BorderThickness="1">

                <StackPanel>

                    <TextBlock Text="Informations Client"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Margin="0,0,0,15"/>

                    <TextBlock Text="ID Client"/>
                    <TextBox x:Name="txtClientId"
                             Height="35"
                             IsReadOnly="True"
                             Background="#F3F4F6"
                             Margin="0,5,0,10"/>

                    <TextBlock Text="Nom"/>
                    <TextBox x:Name="txtNom"
                             Height="35"
                             Margin="0,5,0,10"/>

                    <TextBlock Text="Téléphone"/>
                    <TextBox x:Name="txtTelephone"
                             Height="35"
                             Margin="0,5,0,10"/>

                    <TextBlock Text="Statut client"/>
                    <ComboBox x:Name="cbStatutClient"
                              Height="35"
                              Margin="0,5,0,10">
                        <ComboBoxItem Content="ACTIF"/>
                        <ComboBoxItem Content="INACTIF"/>
                        <ComboBoxItem Content="NOUVEAU"/>
                    </ComboBox>

                </StackPanel>

            </Border>

            <!-- ================= WIFI ================= -->
            <Border Grid.Column="1"
                    Background="White"
                    CornerRadius="10"
                    Padding="20"
                    Margin="10"
                    BorderBrush="#E5E7EB"
                    BorderThickness="1">

                <StackPanel>

                    <TextBlock Text="Connexion WiFi"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Margin="0,0,0,15"/>

                    <TextBlock Text="Marque appareil"/>
                    <TextBox x:Name="txtMarque"
                             Height="35"
                             Margin="0,5,0,10"/>

                    <TextBlock Text="Type réseau"/>
                    <ComboBox x:Name="cbTypeReseau"
                              Height="35"
                              Margin="0,5,0,10">
                        <ComboBoxItem Content="4G"/>
                        <ComboBoxItem Content="5G"/>
                        <ComboBoxItem Content="WIFI"/>
                    </ComboBox>

                    <TextBlock Text="Type session"/>
                    <ComboBox x:Name="cbTypeSession"
                              Height="35"
                              Margin="0,5,0,10">
                        <ComboBoxItem Content="NORMAL"/>
                        <ComboBoxItem Content="NIGHT"/>
                        <ComboBoxItem Content="PROMO"/>
                    </ComboBox>

                    <TextBlock Text="Durée (Heures / Minutes)"/>

                    <Grid Margin="0,5,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>

                        <TextBox x:Name="txtHeure"
                                 Height="35"
                                 Margin="0,0,10,0"/>

                        <TextBox x:Name="txtMinute"
                                 Grid.Column="1"
                                 Height="35"/>
                    </Grid>

                    <!-- INFO -->
                    <Grid Margin="0,10,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="Montant"/>
                            <TextBlock x:Name="txtMontant"
                                       Text="0 Ar"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       Foreground="#16A34A"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Heure fin"/>
                            <TextBox x:Name="txtHeureFin"
                                     Height="35"
                                     IsReadOnly="True"
                                     Background="#F3F4F6"/>
                        </StackPanel>

                    </Grid>

                    <TextBlock Text="Date début"/>
                    <TextBox x:Name="txtDateDebut"
                             Height="35"
                             IsReadOnly="True"
                             Background="#F3F4F6"
                             Margin="0,5,0,15"/>

                    <!-- ================= BUTTON (VISIBLE FIX) ================= -->
                    <Button Content="Activer Connexion"
                            Height="42"
                            Background="#2563EB"
                            Foreground="White"
                            BorderThickness="0"
                            Margin="0,10,0,0"
                            VerticalAlignment="Bottom"
                            Click="BtnActiver_Click"/>

                </StackPanel>

            </Border>

        </Grid>

    </ScrollViewer>

</UserControl>